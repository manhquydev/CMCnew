# CMCnew — DEV env template. Copy to .env.dev (server: /root/cmcnew/.env.dev, chmod 600) and fill
# real values. NEVER commit the real file. Dev secrets are SEPARATE from prod — never reuse
# .env.production values here. See docs/decisions/0032-dev-prod-cicd-environment-split.md.
#
#   docker compose -f docker/docker-compose.dev.tls.yml --env-file .env.dev up -d

# ── Database — mint FRESH secrets for dev (do NOT reuse prod) ──────────────────
DB_USER=cmc
DB_NAME=cmc
DB_PASSWORD=CHANGE_ME_DEV_OWNER_PASSWORD          # openssl rand -base64 36
DB_APP_PASSWORD=CHANGE_ME_DEV_APP_PASSWORD         # cmc_app RLS role; also ALTER ROLE post-migrate

# ── App ───────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_DEV_RANDOM                    # openssl rand -base64 48; distinct from prod
COOKIE_SECURE=true                                 # behind Cloudflare TLS → HTTPS-only cookie
DISABLE_CRON=1                                     # dev is pre-prod: keep scheduled jobs off by default

# ── Public origins (dev domains) ──────────────────────────────────────────────
ADMIN_APP_ORIGIN=https://deverp.cmcvn.edu.vn
CORS_ORIGINS=https://deverp.cmcvn.edu.vn,https://devteacher.cmcvn.edu.vn,https://devlms.cmcvn.edu.vn
STAFF_APP_ORIGINS=https://deverp.cmcvn.edu.vn,https://devteacher.cmcvn.edu.vn

# ── Staff SSO (Microsoft Entra) — real SSO, but a DEV redirect URI + DEV secret ─
# The dev callback URIs must be registered on the Entra app registration separately from prod's.
ENTRA_TENANT_ID=FROM_SOURCE_ENV
ENTRA_CLIENT_ID=FROM_SOURCE_ENV
ENTRA_CLIENT_SECRET=FROM_SOURCE_ENV_DEV            # dev client secret, not prod's
STAFF_EMAIL_DOMAIN=cmcvn.edu.vn
SSO_ENABLED=true
ERP_SSO_REDIRECT_URI=https://deverp.cmcvn.edu.vn/api/auth/sso/callback
# Password login runs alongside SSO in dev for test/debug convenience (decision 0031 + 0032).
# SSO stays the primary path; with SEED_MODE unset (→ full), seeded personas also get a password.
STAFF_PASSWORD_LOGIN=true

# ── Microsoft Graph outbound email (optional in dev — leave blank to disable) ──
GRAPH_CLIENT_SECRET=
GRAPH_SENDER_NOTIFY=
GRAPH_SENDER_PAYROLL=
GRAPH_SENDER_HR=

# ── Seed — SEED_MODE is intentionally NOT set here (and not in the dev compose), so it
#    defaults to 'full': every seeded persona gets a real password for dev test automation.
#    This deliberately diverges from prod (which uses bootstrap). Dev holds synthetic data only.
SEED_SUPERADMIN_EMAIL=admin@cmcvn.edu.vn
SEED_SUPERADMIN_PASSWORD=CHANGE_ME_DEV_STRONG      # dev break-glass; retrieve via SSH, never print

# ── Optional ──────────────────────────────────────────────────────────────────
CRM_LEAD_TOKEN=
CALLIO_API_BASE=
CALLIO_API_TOKEN=

# Database — runtime client connects as the non-owner role cmc_app (RLS applies)
DATABASE_URL="postgresql://cmc_app:cmc_app@localhost:5433/cmc?schema=public"
# Owner role — used by prisma migrate / seed (bypasses RLS)
DIRECT_URL="postgresql://cmc:cmc@localhost:5433/cmc?schema=public"

REDIS_URL="redis://localhost:6380"

# Auth
JWT_SECRET="dev-only-change-me-32+chars-aaaaaaaaaaaa"
AUTH_COOKIE_NAME="cmc.session"

# Super admin bootstrap seed (idempotent)
SEED_SUPERADMIN_EMAIL="admin@cmc.local"
SEED_SUPERADMIN_PASSWORD="ChangeMe!123"

# API
API_PORT=4000

# CRM lead-ingest seam — shared token the website sends to crm.leadIngest (unset = endpoint refuses)
CRM_LEAD_TOKEN="dev-only-change-me-lead-token"

# Production: comma-separated allowed origins for CORS
# CORS_ORIGINS="https://admin.cmcvn.edu.vn,https://hoc.cmcvn.edu.vn"

# Callio (Phonenet) call-metrics — KPI cuộc gọi cho sale. Token lấy ở client.callio.vn → Cài đặt
# → Quản lý token. Unset = bỏ qua đồng bộ cuộc gọi (KPI calls = 0, không lỗi). Đọc lịch sử qua
# GET {CALLIO_API_BASE}/call (header `token`); cuộc hợp lệ = direction=outbound & billDuration>5s.
CALLIO_API_BASE="https://clientapi.phonenet.io"
CALLIO_API_TOKEN=""

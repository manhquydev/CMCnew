# Database — runtime client connects as the non-owner role cmc_app (RLS applies)
DATABASE_URL="postgresql://cmc_app:cmc_app@localhost:5433/cmc?schema=public"
# Owner role — used by prisma migrate / seed (bypasses RLS)
DIRECT_URL="postgresql://cmc:cmc@localhost:5433/cmc?schema=public"

REDIS_URL="redis://localhost:6380"

# Auth
JWT_SECRET="dev-only-change-me-32+chars-aaaaaaaaaaaa"
AUTH_COOKIE_NAME="cmc.session"
# Cookie tên phiên LMS (phụ huynh/học sinh) — mặc định 'cmc.lms' nếu để trống.
LMS_COOKIE_NAME="cmc.lms"
# Local dev runs over plain HTTP (http://localhost), where browsers drop Secure cookies.
# Set false for local dev so the auth session cookie is stored; leave unset (Secure) in prod.
COOKIE_SECURE="false"
# Break-glass: cho phép staff (không phải super_admin) đăng nhập bằng mật khẩu thay vì SSO.
# Để trống/false trong production khi SSO_ENABLED=true (chỉ super_admin có break-glass mặc định).
STAFF_PASSWORD_LOGIN="false"

# Super admin bootstrap seed (idempotent)
SEED_SUPERADMIN_EMAIL="admin@cmc.local"
SEED_SUPERADMIN_PASSWORD="ChangeMe!123"
# 'bootstrap' = chỉ seed 1 Facility (HQ) + 1 super_admin. Để trống/'full' = seed đầy đủ tài khoản demo (dev).
SEED_MODE=""

# API
API_PORT=4000
# Tắt các cron nội bộ (nhắc họp PH, email outbox...) — dùng cho test/CI để giữ side-effect-free.
DISABLE_CRON=""

# ── Rate limiting ────────────────────────────────────────────────────────────────────────────────
# Login (per IP+identifier / per IP), cửa sổ dùng chung LOGIN_RATE_WINDOW_MS.
LOGIN_RATE_PAIR_LIMIT=5
LOGIN_RATE_IP_LIMIT=20
LOGIN_RATE_WINDOW_MS=900000
# Web-lead ingest (crm.leadIngest) — số lead tối đa/IP trong cửa sổ LOGIN_RATE_WINDOW_MS.
LEAD_RATE_IP_LIMIT=100
# OTP đăng nhập LMS — số lần yêu cầu OTP tối đa/định danh trong cửa sổ LOGIN_RATE_WINDOW_MS.
OTP_RATE_LIMIT=5

# ── Local blob stores (exercise PDF, ảnh minh chứng buổi học) ───────────────────────────────────
# Backup qua scripts/backup-db.sh (tar cùng dump DB). Xem DEBT.md: chưa phải durable object store.
PDF_STORE_DIR="./.data/pdf"
SESSION_PHOTO_STORE_DIR="./.data/session-photos"

# CRM lead-ingest seam — shared token the website sends to crm.leadIngest (unset = endpoint refuses)
CRM_LEAD_TOKEN="dev-only-change-me-lead-token"

# Production: comma-separated allowed origins for CORS
# CORS_ORIGINS="https://admin.cmcvn.edu.vn,https://hoc.cmcvn.edu.vn"

# Callio (Phonenet) call-metrics — KPI cuộc gọi cho sale. Token lấy ở client.callio.vn → Cài đặt
# → Quản lý token. Unset = bỏ qua đồng bộ cuộc gọi (KPI calls = 0, không lỗi). Đọc lịch sử qua
# GET {CALLIO_API_BASE}/call (header `token`); cuộc hợp lệ = direction=outbound & billDuration>5s.
CALLIO_API_BASE="https://clientapi.phonenet.io"
CALLIO_API_TOKEN=""

# ── SSO gate ──────────────────────────────────────────────────────────────────────────────────────
# Unset or false → all roles use password login (local dev / director bootstrap).
# true in production → password login becomes break-glass (super_admin only); all others use SSO.
# Must be paired with a fully-configured ENTRA_* block; if ssoConfigFromEnv() returns null the
# gate is never triggered even when SSO_ENABLED=true.
SSO_ENABLED="false"

# ── Microsoft Entra app "CMC" — SSO (staff) + Graph email/OTP (parent) ──────────────────────────
# UNSET = SSO + email/OTP tắt: business code vẫn xếp email vào hàng đợi nhưng worker KHÔNG gửi và
# KHÔNG báo lỗi — merge production an toàn, chỉ cần điền các biến dưới là chạy. Xác thực Graph dùng
# CLIENT SECRET (app CMC trên Entra). Chi tiết luồng: docs/auth-sso-otp-redirection.md
ENTRA_TENANT_ID="4dd49669-ef56-4163-9210-dba5b7101600"
ENTRA_CLIENT_ID="bf0f8dc1-48c5-4f1f-9199-d5e5b41e4a75"
ENTRA_CLIENT_SECRET=""        # IT cấp riêng — TUYỆT ĐỐI không commit. Unset = SSO + OTP + email tắt.
ERP_SSO_REDIRECT_URI="http://localhost:4000/auth/sso/callback"  # phải khớp Redirect URI khai trên Entra
STAFF_EMAIL_DOMAIN="cmcvn.edu.vn"                               # khóa SSO: chỉ email đuôi này được vào

# ── Email/OTP sender qua Microsoft Graph (dùng chung secret ở trên) ─────────────────────────────
# GRAPH_TENANT_ID/GRAPH_CLIENT_ID/GRAPH_CLIENT_SECRET là alias của ENTRA_* (để trống = dùng ENTRA_*).
GRAPH_CLIENT_SECRET=""        # = ENTRA_CLIENT_SECRET (để trống nếu đã set ENTRA_CLIENT_SECRET)
GRAPH_TENANT_ID=""
GRAPH_CLIENT_ID=""
# Thay cho secret: có thể xác thực bằng CHỨNG CHỈ (tùy chọn) thay vì client secret.
GRAPH_CERT_PATH=""            # đường dẫn tuyệt đối tới file .pem/.pfx trên máy chủ API (KHÔNG commit)
GRAPH_CERT_PASSWORD=""         # mật khẩu file .pfx (nếu có)
# Ba Shared Mailbox miễn phí (không cần license). Tên ví dụ — thay bằng domain .edu.vn thật.
GRAPH_SENDER_NOTIFY="erp-notify@example.edu.vn"     # thông báo chung / LMS / CRM
GRAPH_SENDER_PAYROLL="payroll@example.edu.vn"        # phiếu lương
GRAPH_SENDER_HR="hr-onboarding@example.edu.vn"       # onboarding nhân sự

# Origin của các app frontend — dùng dựng link kích hoạt / đặt lại mật khẩu trong email.
LMS_APP_ORIGIN="http://localhost:5175"
ADMIN_APP_ORIGIN="http://localhost:5173"

# ── Logging + ops error alert ───────────────────────────────────────────────────────────────────
# pino log level: trace|debug|info|warn|error|fatal. Pretty-printed unless NODE_ENV=production.
LOG_LEVEL="info"
# Số lỗi handler chưa bắt trong cửa sổ 5 phút để kích hoạt cảnh báo (email qua outbox, mailbox notify).
ERROR_ALERT_THRESHOLD=10
# Người nhận cảnh báo lỗi vận hành. Để trống = tắt cảnh báo (chỉ log, không gửi email).
OPS_ALERT_EMAIL=""

# CMCnew — production env template. Copy to .env.production (server: /root/cmcnew/.env.production,
# chmod 600) and fill real values, OR generate with scripts/prod-build-env.sh. NEVER commit the real file.
#
#   docker compose -f docker/docker-compose.prod.tls.yml --env-file .env.production up -d

# ── Database — mint FRESH secrets for prod (do NOT reuse dev) ──────────────────
DB_USER=cmc
DB_NAME=cmc
DB_PASSWORD=CHANGE_ME_STRONG_OWNER_PASSWORD     # openssl rand -base64 36
DB_APP_PASSWORD=CHANGE_ME_STRONG_APP_PASSWORD    # cmc_app RLS role; also ALTER ROLE post-migrate

# ── App ───────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_RANDOM                       # openssl rand -base64 48
COOKIE_SECURE=true                                # behind TLS → HTTPS-only cookie

# ── Public origins (three domains) ────────────────────────────────────────────
ADMIN_APP_ORIGIN=https://erp.cmcvn.edu.vn
CORS_ORIGINS=https://erp.cmcvn.edu.vn,https://teacher.cmcvn.edu.vn,https://hoc.cmcvn.edu.vn
STAFF_APP_ORIGINS=https://erp.cmcvn.edu.vn,https://teacher.cmcvn.edu.vn

# ── Staff SSO (Microsoft Entra) — reuse the org's real app registration ────────
ENTRA_TENANT_ID=FROM_SOURCE_ENV
ENTRA_CLIENT_ID=FROM_SOURCE_ENV
ENTRA_CLIENT_SECRET=FROM_SOURCE_ENV
STAFF_EMAIL_DOMAIN=cmcvn.edu.vn
SSO_ENABLED=true
ERP_SSO_REDIRECT_URI=https://erp.cmcvn.edu.vn/api/auth/sso/callback
# STAFF_PASSWORD_LOGIN=true — runs permanently alongside SSO (decision 0031). SSO stays the
# default onboarding path; password login only works for accounts a super_admin has explicitly
# set a password for (user.setPassword).
STAFF_PASSWORD_LOGIN=true

# ── Microsoft Graph outbound email (reuse org app) ────────────────────────────
GRAPH_CLIENT_SECRET=FROM_SOURCE_ENV
GRAPH_SENDER_NOTIFY=FROM_SOURCE_ENV
GRAPH_SENDER_PAYROLL=FROM_SOURCE_ENV
GRAPH_SENDER_HR=FROM_SOURCE_ENV

# ── Seed (bootstrap: HQ + super_admin + 2 directors) ──────────────────────────
SEED_SUPERADMIN_EMAIL=admin@cmcvn.edu.vn
SEED_SUPERADMIN_PASSWORD=CHANGE_ME_STRONG        # break-glass; retrieve via SSH, never print

# ── Optional ──────────────────────────────────────────────────────────────────
DISABLE_CRON=0
CRM_LEAD_TOKEN=
CALLIO_API_BASE=
CALLIO_API_TOKEN=

// CMCnew — canonical schema (single source of truth).
// Phase 0: identity + multi-facility tenancy foundation. Later phases extend this.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Business roles. Facility scope is enforced via RLS, not via role.
enum Role {
  super_admin
  quan_ly
  head_teacher
  giao_vien
  ke_toan
  hr
  sale
  cskh
  ctv_mkt
  bgd
}

/// The 3 CMC programs. Global (not facility-scoped).
enum Program {
  UCREA
  BRIGHT_IG
  BLACK_HOLE
}

enum StudentLifecycle {
  admitted
  active
  on_hold
  transferred
  withdrawn
  completed
}

enum ClassStatus {
  planned
  open
  running
  closed
  cancelled
}

enum SessionStatus {
  planned
  confirmed
  cancelled
}

enum EnrollmentStatus {
  active
  completed
  reserved
  transferred
  withdrawn
}

enum AttendanceStatus {
  present
  absent
  late
}

/// Audit/chatter timeline entry kinds (Odoo-style record log).
enum RecordEventType {
  created
  updated
  status_changed
  archived
  restored
  note
}

/// A training center (cơ sở). Tenancy boundary — RLS isolates rows by facility.
model Facility {
  id        Int            @id @default(autoincrement())
  code      String         @unique
  name      String
  timezone  String         @default("Asia/Ho_Chi_Minh")
  address   String?
  isActive  Boolean        @default(true) @map("is_active")
  createdAt DateTime       @default(now()) @map("created_at")
  users     UserFacility[]

  @@map("facility")
}

/// A staff/admin account. Students & parents get their own models in later phases.
model AppUser {
  id           String         @id @default(uuid()) @db.Uuid
  email        String         @unique
  phone        String?
  displayName  String         @map("display_name")
  passwordHash String         @map("password_hash")
  roles        Role[]
  primaryRole  Role           @map("primary_role")
  isActive     Boolean        @default(true) @map("is_active")
  /// Bumped on deactivate / role / facility change → invalidates outstanding JWTs.
  tokenVersion Int            @default(0) @map("token_version")
  createdAt    DateTime       @default(now()) @map("created_at")
  facilities   UserFacility[]

  @@map("app_user")
}

/// Many-to-many: which facilities a user may access.
model UserFacility {
  userId     String   @map("user_id") @db.Uuid
  facilityId Int      @map("facility_id")
  user       AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@id([userId, facilityId])
  @@map("user_facility")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 1 — Academic core. Program + Course are GLOBAL (shared catalog, no RLS).
// Everything from ClassBatch down carries facility_id and is RLS-scoped.
// Soft-delete everywhere via `archivedAt` (null = active). Never hard-delete.
// ─────────────────────────────────────────────────────────────────────────────

/// Course catalog — GLOBAL (dùng chung mọi cơ sở). No facility_id, no RLS.
model Course {
  id          String       @id @default(uuid()) @db.Uuid
  code        String       @unique
  name        String
  program     Program
  description String?
  archivedAt  DateTime?    @map("archived_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  batches     ClassBatch[]
  prices      CoursePrice[]
  receipts    Receipt[]

  @@map("course")
}

/// Học sinh — facility-scoped.
model Student {
  id          String           @id @default(uuid()) @db.Uuid
  facilityId  Int              @map("facility_id")
  studentCode String           @unique @map("student_code")
  fullName    String           @map("full_name")
  dateOfBirth DateTime?        @map("date_of_birth") @db.Date
  program     Program
  level       String? // mô hình level chốt ở Phase 2
  lifecycle   StudentLifecycle @default(admitted)
  archivedAt  DateTime?        @map("archived_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  enrollments Enrollment[]
  account         StudentAccount?
  guardians       Guardian[]
  submissions     Submission[]
  starTransactions StarTransaction[]
  rewards         Reward[]
  qualitativeAssessments QualitativeAssessment[]
  finalGrades     FinalGrade[]
  badges          StudentBadge[]
  levelProgresses LevelProgress[]
  receipts        Receipt[]
  afterSaleCases  AfterSaleCase[]
  certificates    Certificate[]

  @@index([facilityId])
  @@map("student")
}

/// Lớp/khóa cụ thể — facility-scoped. Mã B-YYYY-NNNN (sinh nguyên tử).
model ClassBatch {
  id         String         @id @default(uuid()) @db.Uuid
  facilityId Int            @map("facility_id")
  code       String         @unique
  courseId   String         @map("course_id") @db.Uuid
  course     Course         @relation(fields: [courseId], references: [id])
  name       String
  startDate  DateTime?      @map("start_date") @db.Date
  endDate    DateTime?      @map("end_date") @db.Date
  capacity   Int?
  status     ClassStatus    @default(planned)
  archivedAt DateTime?      @map("archived_at")
  createdAt  DateTime       @default(now()) @map("created_at")
  slots      ScheduleSlot[]
  sessions   ClassSession[]
  enrollments Enrollment[]
  exercises  Exercise[]
  parentMeetings ParentMeeting[]

  @@index([facilityId])
  @@map("class_batch")
}

/// Họp phụ huynh định kỳ theo lớp (docs/specs/parent-meeting.md). 1 lịch → nhắc mọi PH có con
/// đang học (enrollment active) trong lớp. remindedAt = cờ idempotency cho cron nhắc T-1 ngày.
enum ParentMeetingStatus {
  scheduled
  done
  cancelled
}

model ParentMeeting {
  id           String              @id @default(uuid()) @db.Uuid
  facilityId   Int                 @map("facility_id")
  classBatchId String              @map("class_batch_id") @db.Uuid
  batch        ClassBatch          @relation(fields: [classBatchId], references: [id], onDelete: Cascade)
  title        String
  scheduledAt  DateTime            @map("scheduled_at")
  location     String?
  note         String?
  status       ParentMeetingStatus @default(scheduled)
  timeConfirmed Boolean             @default(false) @map("time_confirmed")
  remindedAt   DateTime?           @map("reminded_at")
  createdById  String?             @map("created_by_id") @db.Uuid
  createdAt    DateTime            @default(now()) @map("created_at")
  archivedAt   DateTime?           @map("archived_at")

  @@unique([classBatchId, scheduledAt]) // auto-cadence idempotency: re-running generation never duplicates
  @@index([facilityId])
  @@index([classBatchId])
  @@index([status, remindedAt, scheduledAt])
  @@map("parent_meeting")
}

/// Phòng học — facility-scoped.
model Room {
  id         String    @id @default(uuid()) @db.Uuid
  facilityId Int       @map("facility_id")
  code       String
  name       String
  capacity   Int?
  archivedAt DateTime? @map("archived_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@unique([facilityId, code])
  @@index([facilityId])
  @@map("room")
}

/// Khung lịch tuần của lớp → dùng để sinh Session.
model ScheduleSlot {
  id           String     @id @default(uuid()) @db.Uuid
  facilityId   Int        @map("facility_id")
  classBatchId String     @map("class_batch_id") @db.Uuid
  batch        ClassBatch @relation(fields: [classBatchId], references: [id], onDelete: Cascade)
  dayOfWeek    Int        @map("day_of_week") // 0=CN .. 6=T7
  startTime    String     @map("start_time") // HH:mm (ICT)
  endTime      String     @map("end_time")
  roomId       String?    @map("room_id") @db.Uuid
  teacherId    String?    @map("teacher_id") @db.Uuid
  archivedAt   DateTime?  @map("archived_at")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([facilityId])
  @@index([classBatchId])
  @@map("schedule_slot")
}

/// Buổi học cụ thể — sinh từ slot, hoặc buổi bù.
model ClassSession {
  id           String        @id @default(uuid()) @db.Uuid
  facilityId   Int           @map("facility_id")
  classBatchId String        @map("class_batch_id") @db.Uuid
  batch        ClassBatch    @relation(fields: [classBatchId], references: [id], onDelete: Cascade)
  sessionDate  DateTime      @map("session_date") @db.Date
  startTime    String        @map("start_time")
  endTime      String        @map("end_time")
  roomId       String?       @map("room_id") @db.Uuid
  teacherId    String?       @map("teacher_id") @db.Uuid
  status       SessionStatus @default(planned)
  isMakeup     Boolean       @default(false) @map("is_makeup")
  archivedAt   DateTime?     @map("archived_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  attendances  Attendance[]

  @@unique([classBatchId, sessionDate, startTime])
  @@index([facilityId])
  @@map("class_session")
}

/// Ghi danh học sinh vào lớp.
model Enrollment {
  id            String           @id @default(uuid()) @db.Uuid
  facilityId    Int              @map("facility_id")
  classBatchId  String           @map("class_batch_id") @db.Uuid
  batch         ClassBatch       @relation(fields: [classBatchId], references: [id], onDelete: Cascade)
  studentId     String           @map("student_id") @db.Uuid
  student       Student          @relation(fields: [studentId], references: [id])
  status        EnrollmentStatus @default(active)
  opportunityId String?          @map("opportunity_id") // truy vết CRM (Phase 3)
  archivedAt    DateTime?        @map("archived_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  attendances   Attendance[]

  @@unique([classBatchId, studentId])
  @@index([facilityId])
  @@map("enrollment")
}

/// Điểm danh — 1 bản ghi / (session, enrollment).
model Attendance {
  id             String           @id @default(uuid()) @db.Uuid
  facilityId     Int              @map("facility_id")
  classSessionId String           @map("class_session_id") @db.Uuid
  session        ClassSession     @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  enrollmentId   String           @map("enrollment_id") @db.Uuid
  enrollment     Enrollment       @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  status         AttendanceStatus
  excused        Boolean          @default(false)
  note           String?
  markedById     String?          @map("marked_by_id") @db.Uuid
  markedAt       DateTime?        @map("marked_at")
  createdAt      DateTime         @default(now()) @map("created_at")

  @@unique([classSessionId, enrollmentId])
  @@index([facilityId])
  @@map("attendance")
}

/// Bộ đếm sinh mã lớp nguyên tử theo (cơ sở, năm).
model BatchCodeCounter {
  facilityId Int @map("facility_id")
  year       Int
  lastSeq    Int @default(0) @map("last_seq")

  @@id([facilityId, year])
  @@map("batch_code_counter")
}

// ── Audit / Chatter (Odoo-style) — cross-cutting timeline on every record ──

/// Một dòng timeline cho một record bất kỳ (thay đổi field/trạng thái hoặc ghi chú).
model RecordEvent {
  id         String          @id @default(uuid()) @db.Uuid
  facilityId Int?            @map("facility_id") // null cho record global (vd Course)
  entityType String          @map("entity_type")
  entityId   String          @map("entity_id")
  type       RecordEventType
  changes    Json? // [{ field, old, new }]
  body       String? // nội dung ghi chú / lý do (vd lý do hủy lớp)
  actorId    String?         @map("actor_id") @db.Uuid
  createdAt  DateTime        @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([facilityId])
  @@map("record_event")
}

/// Người theo dõi một record (nhận thông báo — Phase sau).
model RecordFollower {
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  userId     String   @map("user_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  @@id([entityType, entityId, userId])
  @@map("record_follower")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 2 — Đánh giá & LMS học sinh. HS/PH có model định danh RIÊNG (tách AppUser).
// Slice S1: Exercise → Submission → Grade → Star → Reward. Spec: phase-02-assessment-lms.
// Bài nộp = đề PDF gốc (1 lần) + lớp annotation JSON (không lưu PDF phẳng).
// ─────────────────────────────────────────────────────────────────────────────

enum ExerciseType {
  homework
  test_entrance
  test_periodic
}

enum ExerciseStatus {
  draft
  published
  closed
}

enum SubmissionStatus {
  draft
  submitted
  graded
}

/// Loại giao dịch sao: + earn / - spent. reference để chống cộng/trừ trùng.
enum StarTxnType {
  homework_completed
  gift_redeemed
  gift_rejected_refund
  manual
}

enum BadgeSource {
  auto
  manual
}

enum LevelProgressStatus {
  pending
  approved
  rejected
}

enum RewardStatus {
  pending
  approved
  rejected
}

enum GuardianRelation {
  father
  mother
  guardian
}

/// Tài khoản đăng nhập của phụ huynh (login chính phía LMS). Định danh riêng, không phải AppUser.
model ParentAccount {
  id           String     @id @default(uuid()) @db.Uuid
  email        String?    @unique
  phone        String?    @unique
  displayName  String     @map("display_name")
  passwordHash String     @map("password_hash")
  isActive     Boolean    @default(true) @map("is_active")
  /// Bump khi khóa tài khoản / đổi quyền → vô hiệu JWT đang phát hành.
  tokenVersion Int        @default(0) @map("token_version")
  createdAt    DateTime   @default(now()) @map("created_at")
  guardians    Guardian[]

  @@map("parent_account")
}

/// Tài khoản đăng nhập tùy chọn của học sinh (PIN/mã đơn giản; HS 3–11 tuổi).
model StudentAccount {
  id           String   @id @default(uuid()) @db.Uuid
  studentId    String   @unique @map("student_id") @db.Uuid
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  loginCode    String   @unique @map("login_code")
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  tokenVersion Int      @default(0) @map("token_version")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("student_account")
}

/// Liên kết phụ huynh ↔ học sinh (sửa lỗ A3 hệ cũ). Facility-scoped qua student.
model Guardian {
  id              String           @id @default(uuid()) @db.Uuid
  facilityId      Int              @map("facility_id")
  parentAccountId String           @map("parent_account_id") @db.Uuid
  parent          ParentAccount    @relation(fields: [parentAccountId], references: [id], onDelete: Cascade)
  studentId       String           @map("student_id") @db.Uuid
  student         Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  relation        GuardianRelation @default(guardian)
  createdAt       DateTime         @default(now()) @map("created_at")

  @@unique([parentAccountId, studentId])
  @@index([facilityId])
  @@index([studentId])
  @@map("guardian")
}

/// Bài tập GV giao theo lớp. Đề gốc PDF lưu 1 lần (content-addressed) ở MinIO.
model Exercise {
  id           String         @id @default(uuid()) @db.Uuid
  facilityId   Int            @map("facility_id")
  classBatchId String         @map("class_batch_id") @db.Uuid
  batch        ClassBatch     @relation(fields: [classBatchId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  basePdfRef   String?        @map("base_pdf_ref")
  maxScore     Float          @default(10) @map("max_score")
  starReward   Int            @default(10) @map("star_reward")
  dueAt        DateTime?      @map("due_at")
  type         ExerciseType   @default(homework)
  status       ExerciseStatus @default(draft)
  createdById  String?        @map("created_by_id") @db.Uuid
  archivedAt   DateTime?      @map("archived_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  submissions  Submission[]

  @@index([facilityId])
  @@index([classBatchId])
  @@map("exercise")
}

/// Bài nộp của HS = answerText? + lớp annotation JSON (HS làm bài trên đề gốc). Không lưu PDF phẳng.
model Submission {
  id              String           @id @default(uuid()) @db.Uuid
  facilityId      Int              @map("facility_id")
  exerciseId      String           @map("exercise_id") @db.Uuid
  exercise        Exercise         @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  studentId       String           @map("student_id") @db.Uuid
  student         Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answerText      String?          @map("answer_text")
  annotationLayer Json?            @map("annotation_layer")
  version         Int              @default(1)
  status          SubmissionStatus @default(draft)
  submittedAt     DateTime?        @map("submitted_at")
  archivedAt      DateTime?        @map("archived_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  grade           Grade?

  @@unique([exerciseId, studentId])
  @@index([facilityId])
  @@map("submission")
}

/// Điểm 1 bài nộp. GV chấm trên bài qua lớp annotation riêng. Publish → HS/PH thấy + cộng sao.
model Grade {
  id              String     @id @default(uuid()) @db.Uuid
  facilityId      Int        @map("facility_id")
  submissionId    String     @unique @map("submission_id") @db.Uuid
  submission      Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  score           Float
  maxScore        Float      @default(10) @map("max_score")
  feedback        String?
  rubric          Json?
  annotationLayer Json?      @map("annotation_layer")
  gradedById      String?    @map("graded_by_id") @db.Uuid
  gradedAt        DateTime   @default(now()) @map("graded_at")
  isPublished     Boolean    @default(false) @map("is_published")
  createdAt       DateTime   @default(now()) @map("created_at")

  @@index([facilityId])
  @@map("grade")
}

/// Quà đổi sao — facility-scoped (mỗi cơ sở tự quản kho). stock -1 = vô hạn.
model Gift {
  id            String    @id @default(uuid()) @db.Uuid
  facilityId    Int       @map("facility_id")
  name          String
  description   String?
  imageUrl      String?   @map("image_url")
  starsRequired Int       @map("stars_required")
  stock         Int       @default(-1)
  program       Program?
  minLevel      String?   @map("min_level")
  isActive      Boolean   @default(true) @map("is_active")
  archivedAt    DateTime? @map("archived_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  rewards       Reward[]

  @@index([facilityId])
  @@map("gift")
}

/// Sổ cái sao (số dư = SUM(amount)). @@unique(type, reference) → earn/redeem idempotent.
model StarTransaction {
  id         String      @id @default(uuid()) @db.Uuid
  facilityId Int         @map("facility_id")
  studentId  String      @map("student_id") @db.Uuid
  student    Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount     Int
  type       StarTxnType
  reference  String?
  createdAt  DateTime    @default(now()) @map("created_at")

  @@unique([type, reference])
  @@index([studentId, createdAt])
  @@index([facilityId])
  @@map("star_transaction")
}

/// Đổi quà: trừ sao + kho nguyên tử; pending → duyệt; rejected → hoàn sao.
model Reward {
  id           String       @id @default(uuid()) @db.Uuid
  facilityId   Int          @map("facility_id")
  studentId    String       @map("student_id") @db.Uuid
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  giftId       String       @map("gift_id") @db.Uuid
  gift         Gift         @relation(fields: [giftId], references: [id])
  starsSpent   Int          @map("stars_spent")
  status       RewardStatus @default(pending)
  reviewedById String?      @map("reviewed_by_id") @db.Uuid
  reviewedAt   DateTime?    @map("reviewed_at")
  reason       String?
  createdAt    DateTime     @default(now()) @map("created_at")

  @@index([studentId])
  @@index([facilityId])
  @@map("reward")
}

/// Thông báo (polymorphic recipient). Fan-out realtime qua SSE. type mở rộng dần tới 16 loại.
model Notification {
  id            String    @id @default(uuid()) @db.Uuid
  facilityId    Int?      @map("facility_id")
  recipientType String    @map("recipient_type")
  recipientId   String    @map("recipient_id") @db.Uuid
  type          String
  payload       Json?
  readAt        DateTime? @map("read_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([recipientType, recipientId, readAt])
  @@index([facilityId])
  @@map("notification")
}

/// Huy hiệu (S3) — danh mục facility-scoped. unlockCriteria (Json) do @cmc/domain-rewards diễn giải.
model Badge {
  id             String         @id @default(uuid()) @db.Uuid
  facilityId     Int            @map("facility_id")
  code           String         @map("code")
  name           String
  description    String?
  iconUrl        String?        @map("icon_url")
  unlockCriteria Json           @map("unlock_criteria")
  isActive       Boolean        @default(true) @map("is_active")
  archivedAt     DateTime?      @map("archived_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  awards         StudentBadge[]

  @@unique([facilityId, code])
  @@index([facilityId])
  @@map("badge")
}

/// Huy hiệu HS đã đạt (S3). 1 lần/(student, badge). source = auto (đạt tiêu chí) | manual (GV cấp).
model StudentBadge {
  id          String      @id @default(uuid()) @db.Uuid
  facilityId  Int         @map("facility_id")
  studentId   String      @map("student_id") @db.Uuid
  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  badgeId     String      @map("badge_id") @db.Uuid
  badge       Badge       @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  source      BadgeSource @default(auto)
  awardedById String?     @map("awarded_by_id") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at")

  @@unique([studentId, badgeId])
  @@index([studentId])
  @@index([facilityId])
  @@map("student_badge")
}

/// Tiến trình lên cấp độ (S3). GV đề xuất (pending) → head_teacher duyệt (approved → ghi
/// Student.level) / từ chối (rejected). Audit/chatter đầy đủ.
model LevelProgress {
  id           String              @id @default(uuid()) @db.Uuid
  facilityId   Int                 @map("facility_id")
  studentId    String              @map("student_id") @db.Uuid
  student      Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fromLevel    String?             @map("from_level")
  toLevel      String              @map("to_level")
  status       LevelProgressStatus @default(pending)
  reason       String?
  proposedById String?             @map("proposed_by_id") @db.Uuid
  reviewedById String?             @map("reviewed_by_id") @db.Uuid
  reviewedAt   DateTime?           @map("reviewed_at")
  createdAt    DateTime            @default(now()) @map("created_at")

  @@index([studentId])
  @@index([facilityId, status])
  @@map("level_progress")
}

/// Học bạ & tổng hợp (Phase 2 / S2). Logic số nằm ở @cmc/domain-grading.

enum AssessmentPeriod {
  MONTHLY
  END_LEVEL
}

/// Cấu hình chấm theo chương trình — facility-scoped catalog. formula = trọng số định lượng
/// { homework, test, attendance }; criteria = danh sách pillar định tính.
model GradingTemplate {
  id         String             @id @default(uuid()) @db.Uuid
  facilityId Int                @map("facility_id")
  program    Program
  level      String?
  formula    Json
  criteria   Json?
  thresholds GradingThreshold[]
  archivedAt DateTime?          @map("archived_at")
  createdAt  DateTime           @default(now()) @map("created_at")

  @@unique([facilityId, program, level])
  @@index([facilityId])
  @@map("grading_template")
}

/// Ngưỡng % → điểm chữ + kết quả (đạt/chưa), theo template. sequence để sắp xếp.
model GradingThreshold {
  id         String          @id @default(uuid()) @db.Uuid
  facilityId Int             @map("facility_id")
  templateId String          @map("template_id") @db.Uuid
  template   GradingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  minPercent Float           @map("min_percent")
  maxPercent Float           @map("max_percent")
  grade      String
  result     String
  sequence   Int             @default(0)

  @@index([templateId])
  @@index([facilityId])
  @@map("grading_threshold")
}

/// Đánh giá định tính theo (student, period). criteria = { pillar: 0..10 }. 1/(student, periodKey).
model QualitativeAssessment {
  id           String           @id @default(uuid()) @db.Uuid
  facilityId   Int              @map("facility_id")
  studentId    String           @map("student_id") @db.Uuid
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  program      Program?
  level        String?
  period       AssessmentPeriod
  periodKey    String           @map("period_key")
  criteria     Json
  narrative    String?
  assessedById String?          @map("assessed_by_id") @db.Uuid
  archivedAt   DateTime?        @map("archived_at")
  createdAt    DateTime         @default(now()) @map("created_at")

  @@unique([studentId, periodKey])
  @@index([facilityId])
  @@map("qualitative_assessment")
}

/// FinalGrade tổng hợp theo (student, program, period). Idempotent theo khóa; complete=false khi
/// còn thiếu phần có trọng số (điểm provisional).
model FinalGrade {
  id               String   @id @default(uuid()) @db.Uuid
  facilityId       Int      @map("facility_id")
  studentId        String   @map("student_id") @db.Uuid
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  program          Program
  level            String?
  periodKey        String   @map("period_key")
  homeworkAvg      Float?   @map("homework_avg")
  attendanceRate   Float?   @map("attendance_rate")
  testScore        Float?   @map("test_score")
  qualitativeScore Float?   @map("qualitative_score")
  finalScore       Float?   @map("final_score")
  passed           Boolean  @default(false)
  complete         Boolean  @default(false)
  computedAt       DateTime @default(now()) @map("computed_at")

  @@unique([studentId, program, periodKey])
  @@index([facilityId])
  @@map("final_grade")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 3 — Doanh thu & CRM. Slice S1: giá khóa (effective-dated) + discount tier +
// voucher (consume nguyên tử, sửa M2) + phiếu thu. Logic số ở @cmc/domain-finance.
// Spec: phase-03-revenue-crm. Tất cả facility-scoped (RLS staff-by-facility).
// ─────────────────────────────────────────────────────────────────────────────

enum ReceiptStatus {
  draft
  approved
  sent
  reconciled
  cancelled
}

/// Giá khóa học theo thời điểm (effective-dated). amount = học phí/năm (VND integer).
/// Giá áp cho phiếu = bản mới nhất có effectiveFrom <= ngày lập phiếu.
model CoursePrice {
  id            String    @id @default(uuid()) @db.Uuid
  facilityId    Int       @map("facility_id")
  courseId      String    @map("course_id") @db.Uuid
  course        Course    @relation(fields: [courseId], references: [id])
  amount        Int // VND/năm
  effectiveFrom DateTime  @map("effective_from") @db.Date
  archivedAt    DateTime? @map("archived_at")
  createdById   String?   @map("created_by_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([facilityId])
  @@index([courseId, effectiveFrom])
  @@map("course_price")
}

/// Bậc giảm giá theo số năm đóng trước (config theo cơ sở). Mặc định 1→15,2→20,3→30
/// (router fallback @cmc/domain-finance DEFAULT_DISCOUNT_TIERS nếu cơ sở chưa cấu hình).
model DiscountTier {
  id         String    @id @default(uuid()) @db.Uuid
  facilityId Int       @map("facility_id")
  years      Int
  percent    Int
  archivedAt DateTime? @map("archived_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@unique([facilityId, years])
  @@index([facilityId])
  @@map("discount_tier")
}

/// Voucher khuyến mãi — scope theo cơ sở; multi-use (maxUses). Consume nguyên tử tại
/// receipt.approve: UPDATE ... WHERE used_count < max_uses → 0-row = CONFLICT (sửa M2).
model Voucher {
  id         String    @id @default(uuid()) @db.Uuid
  facilityId Int       @map("facility_id")
  code       String
  percent    Int // 0..100
  maxUses    Int       @default(1) @map("max_uses")
  usedCount  Int       @default(0) @map("used_count")
  validFrom  DateTime? @map("valid_from") @db.Date
  validTo    DateTime? @map("valid_to") @db.Date
  active     Boolean   @default(true)
  archivedAt DateTime? @map("archived_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  receipts   Receipt[]

  @@unique([facilityId, code])
  @@index([facilityId])
  @@map("voucher")
}

/// Phiếu thu — facility-scoped. net = gross × (1 − min(tier+voucher, 35)/100). Mã PT-YYYY-NNNN
/// cấp tại approve. draft→approved→sent→reconciled (+cancelled). Voucher consume tại approve.
model Receipt {
  id                       String        @id @default(uuid()) @db.Uuid
  facilityId               Int           @map("facility_id")
  code                     String?       @unique
  studentId                String        @map("student_id") @db.Uuid
  student                  Student       @relation(fields: [studentId], references: [id])
  courseId                 String        @map("course_id") @db.Uuid
  course                   Course        @relation(fields: [courseId], references: [id])
  period                   String?
  yearsPrepaid             Int           @map("years_prepaid")
  annualPrice              Int           @map("annual_price")
  grossAmount              Int           @map("gross_amount")
  tierPercent              Int           @map("tier_percent")
  voucherId                String?       @map("voucher_id") @db.Uuid
  voucher                  Voucher?      @relation(fields: [voucherId], references: [id])
  voucherPercent           Int           @default(0) @map("voucher_percent")
  effectiveDiscountPercent Int           @map("effective_discount_percent")
  netAmount                Int           @map("net_amount")
  status                   ReceiptStatus @default(draft)
  collectedById            String?       @map("collected_by_id") @db.Uuid
  /// Sales-commission attribution, FROZEN at approve (docs/specs/payroll-v2-commission-design.md):
  /// soldById = the credited CVTV (from the linked opportunity's owner); kind = new vs renewal
  /// (derived at approve, win-back via a fresh funnel opportunity counts as new). opportunityId
  /// links the receipt to the sales funnel. collectedById stays = the cashier.
  soldById                 String?       @map("sold_by_id") @db.Uuid
  kind                     ReceiptKind?
  opportunityId            String?       @map("opportunity_id") @db.Uuid
  approvedById             String?       @map("approved_by_id") @db.Uuid
  approvedAt               DateTime?     @map("approved_at")
  sentAt                   DateTime?     @map("sent_at")
  reconciledAt             DateTime?     @map("reconciled_at")
  reconcileNote            String?       @map("reconcile_note")
  cancelledAt              DateTime?     @map("cancelled_at")
  cancelReason             String?       @map("cancel_reason")
  createdAt                DateTime      @default(now()) @map("created_at")

  @@index([facilityId])
  @@index([studentId])
  @@index([soldById, status])
  @@map("receipt")
}

/// Bộ đếm sinh mã phiếu thu nguyên tử theo (cơ sở, năm).
model ReceiptCodeCounter {
  facilityId Int @map("facility_id")
  year       Int
  lastSeq    Int @default(0) @map("last_seq")

  @@id([facilityId, year])
  @@map("receipt_code_counter")
}

/// CRM pipeline (S2): O1 lead → O2 contacted → O3 test scheduled → O4 tested → O5 enrolled.
/// O3/O4 set bởi auto-hook (S3, từ TestAppointment); O2/O5 manual; cho lùi/re-open (audit).
enum OpportunityStage {
  O1_LEAD
  O2_CONTACTED
  O3_TEST_SCHEDULED
  O4_TESTED
  O5_ENROLLED
}

/// Khách tiềm năng — facility-scoped. phone chuẩn hóa +84, dedup theo (cơ sở, phone).
model Contact {
  id            String        @id @default(uuid()) @db.Uuid
  facilityId    Int           @map("facility_id")
  fullName      String        @map("full_name")
  phone         String
  email         String?
  source        String? // web | walk_in | referral | ...
  note          String?
  archivedAt    DateTime?     @map("archived_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  opportunities Opportunity[]

  @@unique([facilityId, phone])
  @@index([facilityId])
  @@map("contact")
}

/// Cơ hội bán hàng — facility-scoped. 1 opp = 1 HS/SĐT (nhiều con cùng SĐT → nhiều opp, phân biệt
/// studentName). lost = closedAt + lostReason; won = stage O5_ENROLLED + closedAt + nối enrollment.
model Opportunity {
  id          String           @id @default(uuid()) @db.Uuid
  facilityId  Int              @map("facility_id")
  contactId   String           @map("contact_id") @db.Uuid
  contact     Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  studentName String?          @map("student_name")
  program     Program?
  stage       OpportunityStage @default(O1_LEAD)
  /// Sales consultant (CVTV) credited with this opportunity — source of commission attribution
  /// (docs/specs/payroll-v2-commission-design.md). Flows onto the receipt's soldById at approve.
  ownerId     String?          @map("owner_id") @db.Uuid
  lostReason  String?          @map("lost_reason")
  closedAt    DateTime?        @map("closed_at")
  archivedAt  DateTime?        @map("archived_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  tests       TestAppointment[]

  @@index([facilityId])
  @@index([contactId])
  @@index([ownerId])
  @@map("opportunity")
}

/// Doanh thu khách mới vs tái tục (PA2 hoa hồng tính khác nhau). Suy + đóng băng tại approve.
enum ReceiptKind {
  new
  renewal
}

/// Lịch test (S3) — facility-scoped. entrance: gắn opportunity → auto-hook O3 khi tạo, O4 khi chấm.
/// periodic: test định kỳ trong quá trình học (không đổi stage opp).
enum TestType {
  entrance
  periodic
}

enum TestStatus {
  scheduled
  done
  no_show
}

model TestAppointment {
  id            String       @id @default(uuid()) @db.Uuid
  facilityId    Int          @map("facility_id")
  opportunityId String?      @map("opportunity_id") @db.Uuid
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  studentName   String?      @map("student_name")
  type          TestType     @default(entrance)
  scheduledAt   DateTime     @map("scheduled_at")
  status        TestStatus   @default(scheduled)
  score         Float?
  result        String?
  gradedById    String?      @map("graded_by_id") @db.Uuid
  gradedAt      DateTime?    @map("graded_at")
  archivedAt    DateTime?    @map("archived_at")
  createdAt     DateTime     @default(now()) @map("created_at")

  @@index([facilityId])
  @@index([opportunityId])
  @@map("test_appointment")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 5 — After-sale (CSKH). Support cases linked to a student, with a status
// lifecycle + audit/chatter. Facility-scoped (RLS staff-by-facility).
// ─────────────────────────────────────────────────────────────────────────────
enum CaseStatus {
  open
  in_progress
  resolved
  closed
}

enum CasePriority {
  low
  normal
  high
}

model AfterSaleCase {
  id           String       @id @default(uuid()) @db.Uuid
  facilityId   Int          @map("facility_id")
  studentId    String?      @map("student_id") @db.Uuid
  student      Student?     @relation(fields: [studentId], references: [id], onDelete: SetNull)
  contactPhone String?      @map("contact_phone")
  subject      String
  description  String?
  category     String? // complaint | request | inquiry | refund | other (free-text)
  priority     CasePriority @default(normal)
  status       CaseStatus   @default(open)
  assignedToId String?      @map("assigned_to_id") @db.Uuid
  resolvedAt   DateTime?    @map("resolved_at")
  createdById  String?      @map("created_by_id") @db.Uuid
  archivedAt   DateTime?    @map("archived_at")
  createdAt    DateTime     @default(now()) @map("created_at")

  @@index([facilityId])
  @@index([studentId])
  @@map("after_sale_case")
}

/// Chứng chỉ — cấp TAY bởi head_teacher/quan_ly (LMS là nền làm bài tập, không tự cấp bằng;
/// duyệt level-up KHÔNG sinh chứng chỉ). Facility-scoped; render bản in HTML tại /files/certificate/:id.
model Certificate {
  id          String    @id @default(uuid()) @db.Uuid
  facilityId  Int       @map("facility_id")
  studentId   String    @map("student_id") @db.Uuid
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  program     Program
  level       String?
  title       String
  issuedById  String?   @map("issued_by_id") @db.Uuid
  issuedAt    DateTime  @default(now()) @map("issued_at")
  archivedAt  DateTime? @map("archived_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([facilityId])
  @@index([studentId])
  @@map("certificate")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 4 — Nhân sự & Lương. Component-based payslip; PIT 7 bậc ở @cmc/domain-payroll.
// Facility-scoped RLS; "non-HR không thấy lương" enforced at the procedure layer
// (requireRole hr/ke_toan) — RLS hiện chưa có GUC theo role. Spec: phase-04-payroll.
// ─────────────────────────────────────────────────────────────────────────────
enum PayslipStatus {
  draft
  finalized
  paid
}

/// Hồ sơ nhân sự (mở rộng AppUser; userId là khóa, không khai báo quan hệ để giữ AppUser gọn).
model EmploymentProfile {
  id         String    @id @default(uuid()) @db.Uuid
  facilityId Int       @map("facility_id")
  userId     String    @unique @map("user_id") @db.Uuid
  position   String // teacher | sales | lead_teacher | center_director | training_director …
  grade      String? // B1..B4, PT3…
  dependents Int       @default(0)
  /// Callio (Phonenet) extension number — maps this user to their call records for KPI calls
  /// (decision 0010). Null = not on the dialer; call metrics resolve 0 for them.
  callioExt  String?   @map("callio_ext")
  startedAt  DateTime? @map("started_at") @db.Date
  archivedAt DateTime? @map("archived_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([facilityId])
  @@map("employment_profile")
}

/// Snapshot số liệu cuộc gọi Callio theo (nhân sự, kỳ) — đóng băng để payslip tái lập (decision
/// 0010). validCalls = cuộc gọi ra có billDuration > 5s. Facility-scoped RLS; HR/super đọc-ghi.
model CallMetric {
  id           String   @id @default(uuid()) @db.Uuid
  facilityId   Int      @map("facility_id")
  userId       String   @map("user_id") @db.Uuid
  periodKey    String   @map("period_key") // YYYY-MM
  validCalls   Int      @default(0) @map("valid_calls")
  totalCalls   Int      @default(0) @map("total_calls")
  totalTalkSec Int      @default(0) @map("total_talk_sec")
  syncedAt     DateTime @default(now()) @map("synced_at")

  @@unique([userId, periodKey])
  @@index([facilityId, periodKey])
  @@map("call_metric")
}

/// Trạng thái phiếu đánh giá KPI (P05, decision 0011): draft→submitted→confirmed→approved.
enum KpiStatus {
  draft
  submitted
  confirmed
  approved
}

/// Điểm KPI theo (nhân sự, kỳ) — auto tính từ dữ liệu + cho phép cấp trên override có lý do
/// (decision 0011). finalScore = overrideScore ?? autoScore. Mọi override ghi record_event để
/// minh bạch. Facility-scoped RLS. Payslip đọc finalScore khi tính (thay vì HR gõ tay).
/// P05: mở rộng thành phiếu đánh giá (Odoo-style) với workflow draft→submitted→confirmed→approved.
model KpiScore {
  id             String    @id @default(uuid()) @db.Uuid
  facilityId     Int       @map("facility_id")
  userId         String    @map("user_id") @db.Uuid
  periodKey      String    @map("period_key") // YYYY-MM
  block          String // 'training' | 'sales' — quyết định KPI band áp dụng
  autoScore      Float     @map("auto_score") // 0..100 tính từ dữ liệu
  autoBreakdown  Json?     @map("auto_breakdown") // [{ criterion, weight, score }]
  overrideScore  Float?    @map("override_score") // cấp trên chỉnh (0..100); null = dùng auto
  overrideReason String?   @map("override_reason")
  overriddenById String?   @map("overridden_by_id") @db.Uuid
  overriddenAt   DateTime? @map("overridden_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  // P05 workflow fields — phiếu đánh giá KPI kiểu Odoo
  status          KpiStatus @default(draft)
  criterionScores Json?     @map("criterion_scores") // [{key, score}] — điểm từng tiêu chí
  submittedById   String?   @map("submitted_by_id") @db.Uuid
  submittedAt     DateTime? @map("submitted_at")
  confirmedById   String?   @map("confirmed_by_id") @db.Uuid
  confirmedAt     DateTime? @map("confirmed_at")
  approvedById    String?   @map("approved_by_id") @db.Uuid
  approvedAt      DateTime? @map("approved_at")

  @@unique([userId, periodKey])
  @@index([facilityId, periodKey])
  @@map("kpi_score")
}

/// Mức lương hiệu lực theo thời điểm (per nhân sự). Áp dụng bản mới nhất effectiveFrom ≤ kỳ lương.
model SalaryRate {
  id             String    @id @default(uuid()) @db.Uuid
  facilityId     Int       @map("facility_id")
  userId         String    @map("user_id") @db.Uuid
  baseSalary     Int       @map("base_salary")
  mealAllowance  Int       @default(0) @map("meal_allowance")
  otherAllowance Int       @default(0) @map("other_allowance")
  kpiMax         Int       @default(0) @map("kpi_max")
  /// Chỉ tiêu doanh số tháng (VND) — mẫu số tính % đạt quota cho hoa hồng sale (PA2). 0 = không áp.
  monthlyQuota   Int       @default(0) @map("monthly_quota")
  effectiveFrom  DateTime  @map("effective_from") @db.Date
  archivedAt     DateTime? @map("archived_at")
  createdById    String?   @map("created_by_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([facilityId])
  @@index([userId, effectiveFrom])
  @@map("salary_rate")
}

/// Chính sách thu nhập effective-dated, company-wide (docs/specs/payroll-v2-commission-design.md).
/// `params` (JSON, validate bằng Zod ở @cmc/domain-payroll) chứa TOÀN BỘ tham số tunable: bảng %
/// hoa hồng theo bậc quota, % tái tục, KPI band theo khối, đơn giá vượt giờ, gói parttime, bậc PIT +
/// giảm trừ. Chỉ super_admin sửa (write); payslip đọc bản hiệu lực ≤ kỳ. Finalize đóng băng số đã
/// tính → sửa policy chỉ áp dụng kỳ sau (quá khứ an toàn). Không facility-scoped (chính sách toàn hệ).
model CompensationPolicy {
  id            String    @id @default(uuid()) @db.Uuid
  effectiveFrom DateTime  @map("effective_from") @db.Date
  params        Json
  note          String?
  createdById   String?   @map("created_by_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")
  archivedAt    DateTime? @map("archived_at")

  @@index([effectiveFrom])
  @@map("compensation_policy")
}

/// Phiếu lương theo (nhân sự, kỳ YYYY-MM). Số liệu khớp @cmc/domain-payroll. Finalize gating (M6):
/// chỉ tính lại khi draft; finalized đóng băng; paid = đã trả.
model Payslip {
  id                 String        @id @default(uuid()) @db.Uuid
  facilityId         Int           @map("facility_id")
  userId             String        @map("user_id") @db.Uuid
  periodKey          String        @map("period_key") // YYYY-MM
  standardDays       Int           @map("standard_days")
  workdays           Int
  kpiScore           Float         @map("kpi_score")
  kpiGrade           String        @map("kpi_grade")
  baseEarned         Int           @map("base_earned")
  allowanceEarned    Int           @map("allowance_earned")
  kpiBonus           Int           @map("kpi_bonus")
  variablePay        Int           @default(0) @map("variable_pay")
  variableNote       String?       @map("variable_note")
  insuranceDeduction Int           @default(0) @map("insurance_deduction")
  dependents         Int           @default(0)
  grossIncome        Int           @map("gross_income")
  taxableIncome      Int           @map("taxable_income")
  pitAmount          Int           @map("pit_amount")
  netIncome          Int           @map("net_income")
  status             PayslipStatus @default(draft)
  computedById       String?       @map("computed_by_id") @db.Uuid
  finalizedById      String?       @map("finalized_by_id") @db.Uuid
  finalizedAt        DateTime?     @map("finalized_at")
  paidAt             DateTime?     @map("paid_at")
  createdAt          DateTime      @default(now()) @map("created_at")

  @@unique([userId, periodKey])
  @@index([facilityId, periodKey])
  @@map("payslip")
}

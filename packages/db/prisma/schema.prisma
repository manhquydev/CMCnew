// CMCnew — canonical schema (single source of truth).
// Phase 0: identity + multi-facility tenancy foundation. Later phases extend this.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Business roles. Facility scope is enforced via RLS, not via role.
/// quan_ly/head_teacher/bgd retired 2026-07 (RBAC role consolidation) — absorbed by the two
/// director roles below.
enum Role {
  super_admin
  giao_vien
  ke_toan
  hr
  sale
  cskh
  ctv_mkt
  giam_doc_kinh_doanh // Business Director — delegates sale/cskh/ctv_mkt/ke_toan/hr team creation
  giam_doc_dao_tao // Education Director — delegates giao_vien team creation
}

/// The 3 CMC programs. Global (not facility-scoped).
enum Program {
  UCREA
  BRIGHT_IG
  BLACK_HOLE
}

/// A curriculum unit is either a teaching unit or a review/exam unit.
enum UnitType {
  LESSON
  REVIEW
}

enum StudentLifecycle {
  admitted
  active
  on_hold
  transferred
  withdrawn
  completed
}

enum ClassStatus {
  planned
  open
  running
  closed
  cancelled
}

enum SessionStatus {
  planned
  confirmed
  cancelled
}

enum SessionEvidenceStatus {
  draft
  published
}

enum EnrollmentStatus {
  active
  completed
  reserved
  transferred
  withdrawn
}

enum AttendanceStatus {
  present
  absent
  late
}

/// Audit/chatter timeline entry kinds (Odoo-style record log).
enum RecordEventType {
  created
  updated
  status_changed
  archived
  restored
  note
}

/// A training center (cơ sở). Tenancy boundary — RLS isolates rows by facility.
model Facility {
  id                 Int                 @id @default(autoincrement())
  code               String              @unique
  name               String
  timezone           String              @default("Asia/Ho_Chi_Minh")
  address            String?
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  users              UserFacility[]
  staffNotifications StaffNotification[]

  @@map("facility")
}

/// A staff/admin account. Students & parents get their own models in later phases.
model AppUser {
  id                       String              @id @default(uuid()) @db.Uuid
  email                    String              @unique
  phone                    String?
  displayName              String              @map("display_name")
  passwordHash             String              @map("password_hash")
  roles                    Role[]
  primaryRole              Role                @map("primary_role")
  isActive                 Boolean             @default(true) @map("is_active")
  /// Bumped on deactivate / role / facility change → invalidates outstanding JWTs.
  tokenVersion             Int                 @default(0) @map("token_version")
  createdAt                DateTime            @default(now()) @map("created_at")
  facilities               UserFacility[]
  staffNotifications       StaffNotification[]
  /// Sessions where this user is the assigned teacher.
  classSessions            ClassSession[]      @relation("SessionTeacher")
  sessionEvidenceCreated   SessionEvidence[]   @relation("SessionEvidenceCreatedBy")
  sessionEvidencePublished SessionEvidence[]   @relation("SessionEvidencePublishedBy")

  @@map("app_user")
}

/// Many-to-many: which facilities a user may access.
model UserFacility {
  userId     String   @map("user_id") @db.Uuid
  facilityId Int      @map("facility_id")
  user       AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@id([userId, facilityId])
  @@map("user_facility")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 1 — Academic core. Program + Course are GLOBAL (shared catalog, no RLS).
// Everything from ClassBatch down carries facility_id and is RLS-scoped.
// Soft-delete everywhere via `archivedAt` (null = active). Never hard-delete.
// ─────────────────────────────────────────────────────────────────────────────

/// Course catalog — GLOBAL (dùng chung mọi cơ sở). No facility_id, no RLS.
model Course {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique
  name        String
  program     Program
  levelCode   String?          @map("level_code")
  description String?
  archivedAt  DateTime?        @map("archived_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  batches     ClassBatch[]
  prices      CoursePrice[]
  receipts    Receipt[]
  units       CurriculumUnit[]

  @@map("course")
}

/// Hard-coded curriculum framework unit — global (not facility-scoped), seeded from
/// curriculum_units_seed.csv. One unit expands into `sessions` real ClassSessions when a class runs.
/// No RLS: readable app-wide via GRANT like `course`; any future mutation MUST gate at the app layer.
model CurriculumUnit {
  id            String         @id @default(uuid()) @db.Uuid
  courseId      String         @map("course_id") @db.Uuid
  course        Course         @relation(fields: [courseId], references: [id])
  unitCode      String         @unique @map("unit_code")
  seqInLevel    Int            @map("seq_in_level")
  orderGlobal   Int            @map("order_global")
  unitType      UnitType       @map("unit_type")
  assessment    String?
  theme         String
  content       String?
  thinkingGoal  String?        @map("thinking_goal")
  sessions      Int
  createdAt     DateTime       @default(now()) @map("created_at")
  classSessions ClassSession[]
  exercises     Exercise[]

  @@index([courseId, orderGlobal])
  @@map("curriculum_unit")
}

/// Học sinh — facility-scoped.
model Student {
  id                     String                  @id @default(uuid()) @db.Uuid
  facilityId             Int                     @map("facility_id")
  studentCode            String                  @map("student_code")
  fullName               String                  @map("full_name")
  dateOfBirth            DateTime?               @map("date_of_birth") @db.Date
  program                Program
  level                  String? // mô hình level chốt ở Phase 2
  lifecycle              StudentLifecycle        @default(admitted)
  archivedAt             DateTime?               @map("archived_at")
  createdAt              DateTime                @default(now()) @map("created_at")
  /// Set only when THIS receipt atomically created this student at approve time.
  /// Null for pre-existing students (seed, dedupe-matched, manually created before F1).
  /// Never set on dedupe-match (reuse): provenance tracks who CREATED, not who paid.
  createdByReceiptId     String?                 @map("created_by_receipt_id") @db.Uuid
  createdByReceipt       Receipt?                @relation("StudentProvenance", fields: [createdByReceiptId], references: [id], onDelete: SetNull)
  enrollments            Enrollment[]
  account                StudentAccount?
  guardians              Guardian[]
  submissions            Submission[]
  starTransactions       StarTransaction[]
  rewards                Reward[]
  qualitativeAssessments QualitativeAssessment[]
  finalGrades            FinalGrade[]
  badges                 StudentBadge[]
  levelProgresses        LevelProgress[]
  receipts               Receipt[]               @relation("ReceiptStudent")
  afterSaleCases         AfterSaleCase[]
  certificates           Certificate[]
  sessionComments        SessionStudentComment[]

  // studentCode is unique per facility — derived from receipt counter (HS-YYYY-NNNN ← PT-YYYY-NNNN),
  // so two facilities will produce the same code independently. Same pattern as ClassBatch + Receipt.
  @@unique([facilityId, studentCode])
  @@index([facilityId])
  @@index([createdByReceiptId])
  @@map("student")
}

/// Lớp/khóa cụ thể — facility-scoped. Mã B-YYYY-NNNN (sinh nguyên tử).
/// code is unique per facility, not globally — two facilities can both have B-2026-0001.
model ClassBatch {
  id             String          @id @default(uuid()) @db.Uuid
  facilityId     Int             @map("facility_id")
  code           String
  courseId       String          @map("course_id") @db.Uuid
  course         Course          @relation(fields: [courseId], references: [id])
  name           String
  startDate      DateTime?       @map("start_date") @db.Date
  endDate        DateTime?       @map("end_date") @db.Date
  capacity       Int?
  status         ClassStatus     @default(planned)
  archivedAt     DateTime?       @map("archived_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  slots          ScheduleSlot[]
  sessions       ClassSession[]
  enrollments    Enrollment[]
  parentMeetings ParentMeeting[]
  receipts       Receipt[]       @relation("ReceiptBatch")

  @@unique([facilityId, code]) // codes are unique per facility; counters are keyed (facilityId, year)
  @@index([facilityId])
  @@map("class_batch")
}

/// Họp phụ huynh định kỳ theo lớp (docs/specs/parent-meeting.md). 1 lịch → nhắc mọi PH có con
/// đang học (enrollment active) trong lớp. remindedAt = cờ idempotency cho cron nhắc T-1 ngày.
enum ParentMeetingStatus {
  scheduled
  done
  cancelled
}

model ParentMeeting {
  id            String              @id @default(uuid()) @db.Uuid
  facilityId    Int                 @map("facility_id")
  classBatchId  String              @map("class_batch_id") @db.Uuid
  batch         ClassBatch          @relation(fields: [classBatchId], references: [id], onDelete: Cascade)
  title         String
  scheduledAt   DateTime            @map("scheduled_at")
  location      String?
  note          String?
  status        ParentMeetingStatus @default(scheduled)
  timeConfirmed Boolean             @default(false) @map("time_confirmed")
  remindedAt    DateTime?           @map("reminded_at")
  createdById   String?             @map("created_by_id") @db.Uuid
  createdAt     DateTime            @default(now()) @map("created_at")
  archivedAt    DateTime?           @map("archived_at")

  @@unique([classBatchId, scheduledAt]) // auto-cadence idempotency: re-running generation never duplicates
  @@index([facilityId])
  @@index([classBatchId])
  @@index([status, remindedAt, scheduledAt])
  @@map("parent_meeting")
}

/// Phòng học — facility-scoped.
model Room {
  id         String         @id @default(uuid()) @db.Uuid
  facilityId Int            @map("facility_id")
  code       String
  name       String
  capacity   Int?
  archivedAt DateTime?      @map("archived_at")
  createdAt  DateTime       @default(now()) @map("created_at")
  sessions   ClassSession[]

  @@unique([facilityId, code])
  @@index([facilityId])
  @@map("room")
}

/// Khung lịch tuần của lớp → dùng để sinh Session.
model ScheduleSlot {
  id           String     @id @default(uuid()) @db.Uuid
  facilityId   Int        @map("facility_id")
  classBatchId String     @map("class_batch_id") @db.Uuid
  batch        ClassBatch @relation(fields: [classBatchId], references: [id], onDelete: Cascade)
  dayOfWeek    Int        @map("day_of_week") // 0=CN .. 6=T7
  startTime    String     @map("start_time") // HH:mm (ICT)
  endTime      String     @map("end_time")
  roomId       String?    @map("room_id") @db.Uuid
  teacherId    String?    @map("teacher_id") @db.Uuid
  archivedAt   DateTime?  @map("archived_at")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([facilityId])
  @@index([classBatchId])
  @@map("schedule_slot")
}

/// Buổi học cụ thể — sinh từ slot, hoặc buổi bù.
model ClassSession {
  id               String           @id @default(uuid()) @db.Uuid
  facilityId       Int              @map("facility_id")
  classBatchId     String           @map("class_batch_id") @db.Uuid
  batch            ClassBatch       @relation(fields: [classBatchId], references: [id], onDelete: Cascade)
  sessionDate      DateTime         @map("session_date") @db.Date
  startTime        String           @map("start_time")
  endTime          String           @map("end_time")
  roomId           String?          @map("room_id") @db.Uuid
  room             Room?            @relation(fields: [roomId], references: [id], onDelete: SetNull)
  teacherId        String?          @map("teacher_id") @db.Uuid
  teacher          AppUser?         @relation("SessionTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  status           SessionStatus    @default(planned)
  isMakeup         Boolean          @default(false) @map("is_makeup")
  curriculumUnitId String?          @map("curriculum_unit_id") @db.Uuid
  curriculumUnit   CurriculumUnit?  @relation(fields: [curriculumUnitId], references: [id], onDelete: SetNull)
  archivedAt       DateTime?        @map("archived_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  attendances      Attendance[]
  evidence         SessionEvidence?

  @@unique([classBatchId, sessionDate, startTime])
  @@index([facilityId])
  @@index([facilityId, sessionDate])
  @@map("class_session")
}

/// Ghi danh học sinh vào lớp.
model Enrollment {
  id                 String           @id @default(uuid()) @db.Uuid
  facilityId         Int              @map("facility_id")
  classBatchId       String           @map("class_batch_id") @db.Uuid
  batch              ClassBatch       @relation(fields: [classBatchId], references: [id], onDelete: Cascade)
  studentId          String           @map("student_id") @db.Uuid
  student            Student          @relation(fields: [studentId], references: [id])
  status             EnrollmentStatus @default(active)
  opportunityId      String?          @map("opportunity_id") // truy vết CRM (Phase 3)
  /// Set when receipt.approve created this enrollment atomically. Used for rollback scoping
  /// in receiptCancel: only enrollments with this receipt's id are wound down.
  createdByReceiptId String?          @map("created_by_receipt_id") @db.Uuid
  createdByReceipt   Receipt?         @relation("EnrollmentProvenance", fields: [createdByReceiptId], references: [id], onDelete: SetNull)
  archivedAt         DateTime?        @map("archived_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  attendances        Attendance[]

  @@unique([classBatchId, studentId])
  @@index([facilityId])
  @@index([createdByReceiptId])
  @@index([studentId])
  @@map("enrollment")
}

/// Điểm danh — 1 bản ghi / (session, enrollment).
model Attendance {
  id             String           @id @default(uuid()) @db.Uuid
  facilityId     Int              @map("facility_id")
  classSessionId String           @map("class_session_id") @db.Uuid
  session        ClassSession     @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  enrollmentId   String           @map("enrollment_id") @db.Uuid
  enrollment     Enrollment       @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  status         AttendanceStatus
  excused        Boolean          @default(false)
  note           String?
  markedById     String?          @map("marked_by_id") @db.Uuid
  markedAt       DateTime?        @map("marked_at")
  createdAt      DateTime         @default(now()) @map("created_at")

  @@unique([classSessionId, enrollmentId])
  @@index([facilityId])
  @@index([enrollmentId])
  @@map("attendance")
}

/// Learning diary evidence for one concrete class session. Draft is staff-only;
/// published is visible in LMS to enrolled/owned students.
model SessionEvidence {
  id             String                  @id @default(uuid()) @db.Uuid
  facilityId     Int                     @map("facility_id")
  classSessionId String                  @unique @map("class_session_id") @db.Uuid
  classSession   ClassSession            @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  summary        String?
  internalNote   String?                 @map("internal_note")
  status         SessionEvidenceStatus   @default(draft)
  publishedAt    DateTime?               @map("published_at")
  publishedById  String?                 @map("published_by_id") @db.Uuid
  publishedBy    AppUser?                @relation("SessionEvidencePublishedBy", fields: [publishedById], references: [id], onDelete: SetNull)
  createdById    String?                 @map("created_by_id") @db.Uuid
  createdBy      AppUser?                @relation("SessionEvidenceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  archivedAt     DateTime?               @map("archived_at")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")
  photos         SessionEvidencePhoto[]
  comments       SessionStudentComment[]

  @@index([facilityId, publishedAt])
  @@index([status])
  @@map("session_evidence")
}

model SessionEvidencePhoto {
  id                String          @id @default(uuid()) @db.Uuid
  sessionEvidenceId String          @map("session_evidence_id") @db.Uuid
  sessionEvidence   SessionEvidence @relation(fields: [sessionEvidenceId], references: [id], onDelete: Cascade)
  photoRef          String          @map("photo_ref")
  sortOrder         Int             @default(0) @map("sort_order")
  createdAt         DateTime        @default(now()) @map("created_at")

  @@index([sessionEvidenceId])
  @@index([photoRef])
  @@map("session_evidence_photo")
}

model SessionStudentComment {
  id                String          @id @default(uuid()) @db.Uuid
  sessionEvidenceId String          @map("session_evidence_id") @db.Uuid
  sessionEvidence   SessionEvidence @relation(fields: [sessionEvidenceId], references: [id], onDelete: Cascade)
  studentId         String          @map("student_id") @db.Uuid
  student           Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  participation     String?
  strength          String?
  needsImprovement  String?         @map("needs_improvement")
  teacherNote       String?         @map("teacher_note")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@unique([sessionEvidenceId, studentId])
  @@index([studentId])
  @@map("session_student_comment")
}

/// Bộ đếm sinh mã lớp nguyên tử theo (cơ sở, năm).
model BatchCodeCounter {
  facilityId Int @map("facility_id")
  year       Int
  lastSeq    Int @default(0) @map("last_seq")

  @@id([facilityId, year])
  @@map("batch_code_counter")
}

// ── Audit / Chatter (Odoo-style) — cross-cutting timeline on every record ──

/// Một dòng timeline cho một record bất kỳ (thay đổi field/trạng thái hoặc ghi chú).
model RecordEvent {
  id         String          @id @default(uuid()) @db.Uuid
  facilityId Int?            @map("facility_id") // null cho record global (vd Course)
  entityType String          @map("entity_type")
  entityId   String          @map("entity_id")
  type       RecordEventType
  changes    Json? // [{ field, old, new }]
  body       String? // nội dung ghi chú / lý do (vd lý do hủy lớp)
  actorId    String?         @map("actor_id") @db.Uuid
  createdAt  DateTime        @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([facilityId])
  @@map("record_event")
}

/// Người theo dõi một record (nhận thông báo — Phase sau).
model RecordFollower {
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  userId     String   @map("user_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  @@id([entityType, entityId, userId])
  @@map("record_follower")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 2 — Đánh giá & LMS học sinh. HS/PH có model định danh RIÊNG (tách AppUser).
// Slice S1: Exercise → Submission → Grade → Star → Reward. Spec: phase-02-assessment-lms.
// Bài nộp = đề PDF gốc (1 lần) + lớp annotation JSON (không lưu PDF phẳng).
// ─────────────────────────────────────────────────────────────────────────────

enum ExerciseType {
  homework
  test_entrance
  test_periodic
}

enum ExerciseStatus {
  draft
  published
  closed
}

enum SubmissionStatus {
  draft
  submitted
  graded
}

/// Loại giao dịch sao: + earn / - spent. reference để chống cộng/trừ trùng.
enum StarTxnType {
  homework_completed
  gift_redeemed
  gift_rejected_refund
  manual
}

enum BadgeSource {
  auto
  manual
}

enum LevelProgressStatus {
  pending
  approved
  rejected
}

enum RewardStatus {
  pending
  approved
  rejected
}

enum GuardianRelation {
  father
  mother
  guardian
}

/// Tài khoản đăng nhập của phụ huynh (login chính phía LMS). Định danh riêng, không phải AppUser.
model ParentAccount {
  id                 String     @id @default(uuid()) @db.Uuid
  email              String?    @unique
  phone              String?    @unique
  displayName        String     @map("display_name")
  /// Nullable: phụ huynh đăng nhập passwordless bằng OTP email; mật khẩu chỉ còn cho tài khoản cũ.
  passwordHash       String?    @map("password_hash")
  isActive           Boolean    @default(true) @map("is_active")
  /// Bump khi khóa tài khoản / đổi quyền → vô hiệu JWT đang phát hành.
  tokenVersion       Int        @default(0) @map("token_version")
  /// Phụ huynh có nhận email thông báo (digest/nhắc lịch) không. Email giao dịch luôn gửi.
  emailNotifications Boolean    @default(true) @map("email_notifications")
  createdAt          DateTime   @default(now()) @map("created_at")
  guardians          Guardian[]

  @@map("parent_account")
}

/// Tài khoản đăng nhập tùy chọn của học sinh (PIN/mã đơn giản; HS 3–11 tuổi).
model StudentAccount {
  id           String   @id @default(uuid()) @db.Uuid
  studentId    String   @unique @map("student_id") @db.Uuid
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  loginCode    String   @unique @map("login_code")
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  tokenVersion Int      @default(0) @map("token_version")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("student_account")
}

/// Liên kết phụ huynh ↔ học sinh (sửa lỗ A3 hệ cũ). Facility-scoped qua student.
model Guardian {
  id              String           @id @default(uuid()) @db.Uuid
  facilityId      Int              @map("facility_id")
  parentAccountId String           @map("parent_account_id") @db.Uuid
  parent          ParentAccount    @relation(fields: [parentAccountId], references: [id], onDelete: Cascade)
  studentId       String           @map("student_id") @db.Uuid
  student         Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  relation        GuardianRelation @default(guardian)
  createdAt       DateTime         @default(now()) @map("created_at")

  @@unique([parentAccountId, studentId])
  @@index([facilityId])
  @@index([studentId])
  @@map("guardian")
}

/// Global curriculum exercise asset. No RLS backstop; every write path must be app-layer gated.
model Exercise {
  id               String         @id @default(uuid()) @db.Uuid
  curriculumUnitId String         @map("curriculum_unit_id") @db.Uuid
  curriculumUnit   CurriculumUnit @relation(fields: [curriculumUnitId], references: [id], onDelete: Restrict)
  title            String
  description      String?
  basePdfRef       String?        @map("base_pdf_ref")
  maxScore         Float          @default(10) @map("max_score")
  starReward       Int            @default(10) @map("star_reward")
  type             ExerciseType   @default(homework)
  status           ExerciseStatus @default(draft)
  createdById      String?        @map("created_by_id") @db.Uuid
  archivedAt       DateTime?      @map("archived_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  submissions      Submission[]

  @@unique([curriculumUnitId, type])
  @@index([curriculumUnitId])
  @@map("exercise")
}

/// Bài nộp của HS = answerText? + lớp annotation JSON (HS làm bài trên đề gốc). Không lưu PDF phẳng.
model Submission {
  id              String           @id @default(uuid()) @db.Uuid
  facilityId      Int              @map("facility_id")
  exerciseId      String           @map("exercise_id") @db.Uuid
  exercise        Exercise         @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  studentId       String           @map("student_id") @db.Uuid
  student         Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answerText      String?          @map("answer_text")
  annotationLayer Json?            @map("annotation_layer")
  version         Int              @default(1)
  status          SubmissionStatus @default(draft)
  submittedAt     DateTime?        @map("submitted_at")
  archivedAt      DateTime?        @map("archived_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  grade           Grade?

  @@unique([exerciseId, studentId])
  @@index([facilityId])
  @@index([studentId])
  @@map("submission")
}

/// Điểm 1 bài nộp. GV chấm trên bài qua lớp annotation riêng. Publish → HS/PH thấy + cộng sao.
model Grade {
  id              String     @id @default(uuid()) @db.Uuid
  facilityId      Int        @map("facility_id")
  submissionId    String     @unique @map("submission_id") @db.Uuid
  submission      Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  score           Float
  maxScore        Float      @default(10) @map("max_score")
  feedback        String?
  rubric          Json?
  annotationLayer Json?      @map("annotation_layer")
  gradedById      String?    @map("graded_by_id") @db.Uuid
  gradedAt        DateTime   @default(now()) @map("graded_at")
  isPublished     Boolean    @default(false) @map("is_published")
  createdAt       DateTime   @default(now()) @map("created_at")

  @@index([facilityId])
  @@map("grade")
}

/// Quà đổi sao — facility-scoped (mỗi cơ sở tự quản kho). stock -1 = vô hạn.
model Gift {
  id            String    @id @default(uuid()) @db.Uuid
  facilityId    Int       @map("facility_id")
  name          String
  description   String?
  imageUrl      String?   @map("image_url")
  starsRequired Int       @map("stars_required")
  stock         Int       @default(-1)
  program       Program?
  minLevel      String?   @map("min_level")
  isActive      Boolean   @default(true) @map("is_active")
  archivedAt    DateTime? @map("archived_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  rewards       Reward[]

  @@index([facilityId])
  @@map("gift")
}

/// Sổ cái sao (số dư = SUM(amount)). Idempotency = partial unique index (type, reference)
/// WHERE reference IS NOT NULL, quản lý bằng raw SQL trong migration — Prisma @@unique không biểu
/// đạt được partial index, và (type, NULL) trong Postgres KHÔNG bị @@unique chặn (mỗi NULL là distinct
/// → cho phép trùng vô hạn). Các loại tự động (homework_completed/gift_redeemed/gift_rejected_refund)
/// luôn có reference non-null nên được index bảo vệ; manual (chưa dùng) bắt buộc reference ở tRPC.
model StarTransaction {
  id         String      @id @default(uuid()) @db.Uuid
  facilityId Int         @map("facility_id")
  studentId  String      @map("student_id") @db.Uuid
  student    Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount     Int
  type       StarTxnType
  reference  String?
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([type, reference])
  @@index([studentId, createdAt])
  @@index([facilityId])
  @@map("star_transaction")
}

/// Đổi quà: trừ sao + kho nguyên tử; pending → duyệt; rejected → hoàn sao.
model Reward {
  id           String       @id @default(uuid()) @db.Uuid
  facilityId   Int          @map("facility_id")
  studentId    String       @map("student_id") @db.Uuid
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  giftId       String       @map("gift_id") @db.Uuid
  gift         Gift         @relation(fields: [giftId], references: [id])
  starsSpent   Int          @map("stars_spent")
  status       RewardStatus @default(pending)
  reviewedById String?      @map("reviewed_by_id") @db.Uuid
  reviewedAt   DateTime?    @map("reviewed_at")
  reason       String?
  createdAt    DateTime     @default(now()) @map("created_at")

  @@index([studentId])
  @@index([facilityId])
  @@map("reward")
}

/// Thông báo (polymorphic recipient). Fan-out realtime qua SSE. type mở rộng dần tới 16 loại.
model Notification {
  id            String    @id @default(uuid()) @db.Uuid
  facilityId    Int?      @map("facility_id")
  recipientType String    @map("recipient_type")
  recipientId   String    @map("recipient_id") @db.Uuid
  type          String
  payload       Json?
  readAt        DateTime? @map("read_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([recipientType, recipientId, readAt])
  @@index([facilityId])
  @@map("notification")
}

/// Trạng thái một email trong outbox.
enum EmailStatus {
  queued
  sending
  sent
  failed
  skipped
}

/// Outbox cho email gửi qua Microsoft Graph (M365). Business code ghi 1 dòng cùng transaction
/// với hành động nghiệp vụ (transactional outbox — atomic + idempotent qua dedupKey). Một worker
/// cron rút hàng đợi với tốc độ giới hạn (≤20/phút < ngưỡng Exchange 30/phút), render & gửi.
/// Khi GRAPH_* env chưa cấu hình, worker để nguyên trạng thái queued (no-op, không lỗi).
/// System-scoped: worker chạy super-bypass; facilityId chỉ để truy vết & RLS cho staff khi enqueue.
model EmailOutbox {
  id           String      @id @default(uuid()) @db.Uuid
  facilityId   Int?        @map("facility_id")
  dedupKey     String      @unique @map("dedup_key")
  toAddress    String      @map("to_address")
  mailbox      String
  templateKind String      @map("template_kind")
  subject      String
  bodyHtml     String      @map("body_html")
  attachRef    String?     @map("attach_ref")
  status       EmailStatus @default(queued)
  attempts     Int         @default(0)
  lastError    String?     @map("last_error")
  scheduledFor DateTime    @default(now()) @map("scheduled_for")
  sentAt       DateTime?   @map("sent_at")
  createdAt    DateTime    @default(now()) @map("created_at")

  @@index([status, scheduledFor])
  @@index([facilityId])
  @@map("email_outbox")
}

/// Mã OTP đăng nhập passwordless cho phụ huynh (LMS). Lưu HASH của email + code (không lưu thô).
/// Hết hạn ngắn (5 phút), 1 lần, đếm số lần thử để chặn dò mã 6 số. System-scoped (super-only RLS).
model LoginOtp {
  id         String    @id @default(uuid()) @db.Uuid
  emailHash  String    @map("email_hash")
  codeHash   String    @map("code_hash")
  expiresAt  DateTime  @map("expires_at")
  attempts   Int       @default(0)
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([emailHash, createdAt])
  @@map("login_otp")
}

/// Huy hiệu (S3) — danh mục facility-scoped. unlockCriteria (Json) do @cmc/domain-rewards diễn giải.
model Badge {
  id             String         @id @default(uuid()) @db.Uuid
  facilityId     Int            @map("facility_id")
  code           String         @map("code")
  name           String
  description    String?
  iconUrl        String?        @map("icon_url")
  unlockCriteria Json           @map("unlock_criteria")
  isActive       Boolean        @default(true) @map("is_active")
  archivedAt     DateTime?      @map("archived_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  awards         StudentBadge[]

  @@unique([facilityId, code])
  @@index([facilityId])
  @@map("badge")
}

/// Huy hiệu HS đã đạt (S3). 1 lần/(student, badge). source = auto (đạt tiêu chí) | manual (GV cấp).
model StudentBadge {
  id          String      @id @default(uuid()) @db.Uuid
  facilityId  Int         @map("facility_id")
  studentId   String      @map("student_id") @db.Uuid
  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  badgeId     String      @map("badge_id") @db.Uuid
  badge       Badge       @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  source      BadgeSource @default(auto)
  awardedById String?     @map("awarded_by_id") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at")

  @@unique([studentId, badgeId])
  @@index([studentId])
  @@index([facilityId])
  @@map("student_badge")
}

/// Tiến trình lên cấp độ (S3). GV đề xuất (pending) → head_teacher duyệt (approved → ghi
/// Student.level) / từ chối (rejected). Audit/chatter đầy đủ.
model LevelProgress {
  id           String              @id @default(uuid()) @db.Uuid
  facilityId   Int                 @map("facility_id")
  studentId    String              @map("student_id") @db.Uuid
  student      Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fromLevel    String?             @map("from_level")
  toLevel      String              @map("to_level")
  status       LevelProgressStatus @default(pending)
  reason       String?
  proposedById String?             @map("proposed_by_id") @db.Uuid
  reviewedById String?             @map("reviewed_by_id") @db.Uuid
  reviewedAt   DateTime?           @map("reviewed_at")
  createdAt    DateTime            @default(now()) @map("created_at")

  @@index([studentId])
  @@index([facilityId, status])
  @@map("level_progress")
}

/// Học bạ & tổng hợp (Phase 2 / S2). Logic số nằm ở @cmc/domain-grading.

enum AssessmentPeriod {
  MONTHLY
  END_LEVEL
}

/// Cấu hình chấm theo chương trình — facility-scoped catalog. formula = trọng số định lượng
/// { homework, test, attendance }; criteria = danh sách pillar định tính.
/// qualitativeWeight / quantitativeWeight: khi NULL (mặc định) → router dùng hằng số charter
/// từ programWeights() trong @cmc/domain-grading (UCREA=1/0, BRIGHT_IG=0.6/0.4, BLACK_HOLE=0.3/0.7).
/// Khi cả hai đều non-null → override tường minh cho template này (phải cộng = 1).
/// Không bao giờ đặt giá trị mặc định trong DB; nguồn chân lý là @cmc/domain-grading.
model GradingTemplate {
  id                 String    @id @default(uuid()) @db.Uuid
  facilityId         Int       @map("facility_id")
  program            Program
  level              String?
  formula            Json
  criteria           Json?
  /// NULL = use programWeights() charter constant. Non-null = explicit per-template override.
  qualitativeWeight  Float?    @map("qualitative_weight")
  /// NULL = use programWeights() charter constant. Non-null = explicit per-template override.
  quantitativeWeight Float?    @map("quantitative_weight")
  archivedAt         DateTime? @map("archived_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  @@unique([facilityId, program, level])
  @@index([facilityId])
  @@map("grading_template")
}

/// Đánh giá định tính theo (student, period). criteria = { pillar: 0..10 }. 1/(student, periodKey).
model QualitativeAssessment {
  id           String           @id @default(uuid()) @db.Uuid
  facilityId   Int              @map("facility_id")
  studentId    String           @map("student_id") @db.Uuid
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  program      Program?
  level        String?
  period       AssessmentPeriod
  periodKey    String           @map("period_key")
  criteria     Json
  narrative    String?
  assessedById String?          @map("assessed_by_id") @db.Uuid
  archivedAt   DateTime?        @map("archived_at")
  createdAt    DateTime         @default(now()) @map("created_at")

  @@unique([studentId, periodKey])
  @@index([facilityId])
  @@map("qualitative_assessment")
}

/// FinalGrade tổng hợp theo (student, program, period). Idempotent theo khóa; complete=false khi
/// còn thiếu phần có trọng số (điểm provisional).
model FinalGrade {
  id               String   @id @default(uuid()) @db.Uuid
  facilityId       Int      @map("facility_id")
  studentId        String   @map("student_id") @db.Uuid
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  program          Program
  level            String?
  periodKey        String   @map("period_key")
  homeworkAvg      Float?   @map("homework_avg")
  attendanceRate   Float?   @map("attendance_rate")
  testScore        Float?   @map("test_score")
  qualitativeScore Float?   @map("qualitative_score")
  finalScore       Float?   @map("final_score")
  passed           Boolean  @default(false)
  complete         Boolean  @default(false)
  computedAt       DateTime @default(now()) @map("computed_at")

  @@unique([studentId, program, periodKey])
  @@index([facilityId])
  @@map("final_grade")
}

/// Kỳ học có mốc ngày (decision 2026-06-26): final grade gộp điểm/điểm danh TRONG khoảng kỳ.
/// periodKey khớp với FinalGrade/QualitativeAssessment.periodKey; computeFinalGrade lọc theo
/// [startDate, endDate]. Không có term cho periodKey → fallback all-time (tương thích ngược).
/// isLocked=true → chặn mọi mutation FinalGrade trong kỳ (chốt điểm cuối kỳ). Gated by quan_ly/head_teacher.
model AcademicTerm {
  id         String   @id @default(uuid()) @db.Uuid
  facilityId Int      @map("facility_id")
  periodKey  String   @map("period_key")
  name       String
  startDate  DateTime @map("start_date") @db.Date
  endDate    DateTime @map("end_date") @db.Date
  program    Program?
  isLocked   Boolean  @default(false) @map("is_locked")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([facilityId, periodKey])
  @@index([facilityId])
  @@map("academic_term")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 3 — Doanh thu & CRM. Slice S1: giá khóa (effective-dated) + discount tier +
// voucher (consume nguyên tử, sửa M2) + phiếu thu. Logic số ở @cmc/domain-finance.
// Spec: phase-03-revenue-crm. Tất cả facility-scoped (RLS staff-by-facility).
// ─────────────────────────────────────────────────────────────────────────────

enum ReceiptStatus {
  draft
  approved
  sent
  reconciled
  cancelled
}

/// Giá khóa học theo thời điểm (effective-dated). amount = học phí/năm (VND integer).
/// Giá áp cho phiếu = bản mới nhất có effectiveFrom <= ngày lập phiếu.
model CoursePrice {
  id            String    @id @default(uuid()) @db.Uuid
  facilityId    Int       @map("facility_id")
  courseId      String    @map("course_id") @db.Uuid
  course        Course    @relation(fields: [courseId], references: [id])
  amount        Int // VND/năm
  effectiveFrom DateTime  @map("effective_from") @db.Date
  archivedAt    DateTime? @map("archived_at")
  createdById   String?   @map("created_by_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")

  // Một giá hiệu lực duy nhất cho mỗi (cơ sở, khóa, ngày hiệu lực) → tránh giá không xác định.
  @@unique([facilityId, courseId, effectiveFrom])
  @@index([facilityId])
  @@index([courseId, effectiveFrom])
  @@map("course_price")
}

/// Bậc giảm giá theo số năm đóng trước (config theo cơ sở). Mặc định 1→15,2→20,3→30
/// (router fallback @cmc/domain-finance DEFAULT_DISCOUNT_TIERS nếu cơ sở chưa cấu hình).
model DiscountTier {
  id         String    @id @default(uuid()) @db.Uuid
  facilityId Int       @map("facility_id")
  years      Int
  percent    Int
  archivedAt DateTime? @map("archived_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@unique([facilityId, years])
  @@index([facilityId])
  @@map("discount_tier")
}

/// Voucher khuyến mãi — scope theo cơ sở; multi-use (maxUses). Consume nguyên tử tại
/// receipt.approve: UPDATE ... WHERE used_count < max_uses → 0-row = CONFLICT (sửa M2).
model Voucher {
  id         String    @id @default(uuid()) @db.Uuid
  facilityId Int       @map("facility_id")
  code       String
  percent    Int // 0..100
  maxUses    Int       @default(1) @map("max_uses")
  usedCount  Int       @default(0) @map("used_count")
  validFrom  DateTime? @map("valid_from") @db.Date
  validTo    DateTime? @map("valid_to") @db.Date
  active     Boolean   @default(true)
  archivedAt DateTime? @map("archived_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  receipts   Receipt[]

  @@unique([facilityId, code])
  @@index([facilityId])
  @@map("voucher")
}

/// Phiếu thu — facility-scoped. net = gross × (1 − min(tier+voucher, 35)/100). Mã PT-YYYY-NNNN
/// cấp tại approve. draft→approved→sent→reconciled (+cancelled). Voucher consume tại approve.
/// Student provisioning (F1): studentId is nullable for the NEW-student path. If parentPhone+studentName
/// are present and studentId is null, receipt.approve creates/dedupes the Student atomically.
/// code is unique per facility, not globally — two facilities can both have PT-2026-0001.
model Receipt {
  id                       String        @id @default(uuid()) @db.Uuid
  facilityId               Int           @map("facility_id")
  code                     String?
  /// Nullable: null until receipt.approve resolves or creates the student (new-student provisioning).
  /// Set immediately when the receipt is for an existing student (renewal/explicit-link path).
  studentId                String?       @map("student_id") @db.Uuid
  student                  Student?      @relation("ReceiptStudent", fields: [studentId], references: [id])
  courseId                 String        @map("course_id") @db.Uuid
  course                   Course        @relation(fields: [courseId], references: [id])
  period                   String?
  yearsPrepaid             Int           @map("years_prepaid")
  annualPrice              Int           @map("annual_price")
  grossAmount              Int           @map("gross_amount")
  tierPercent              Int           @map("tier_percent")
  voucherId                String?       @map("voucher_id") @db.Uuid
  voucher                  Voucher?      @relation(fields: [voucherId], references: [id])
  voucherPercent           Int           @default(0) @map("voucher_percent")
  effectiveDiscountPercent Int           @map("effective_discount_percent")
  netAmount                Int           @map("net_amount")
  status                   ReceiptStatus @default(draft)
  collectedById            String?       @map("collected_by_id") @db.Uuid
  /// Sales-commission attribution, FROZEN at approve (docs/specs/payroll-v2-commission-design.md):
  /// soldById = the credited CVTV (from the linked opportunity's owner); kind = new vs renewal
  /// (derived at approve, win-back via a fresh funnel opportunity counts as new). opportunityId
  /// links the receipt to the sales funnel. collectedById stays = the cashier.
  soldById                 String?       @map("sold_by_id") @db.Uuid
  kind                     ReceiptKind?
  opportunityId            String?       @map("opportunity_id") @db.Uuid
  opportunity              Opportunity?  @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  approvedById             String?       @map("approved_by_id") @db.Uuid
  approvedAt               DateTime?     @map("approved_at")
  sentAt                   DateTime?     @map("sent_at")
  reconciledAt             DateTime?     @map("reconciled_at")
  reconcileNote            String?       @map("reconcile_note")
  cancelledAt              DateTime?     @map("cancelled_at")
  cancelReason             String?       @map("cancel_reason")
  createdAt                DateTime      @default(now()) @map("created_at")
  /// New-student provisioning fields (F1). Only populated when this receipt creates a new student.
  parentPhone              String?       @map("parent_phone") // dedupe key via ParentAccount.phone
  parentName               String?       @map("parent_name") // display name for ParentAccount
  parentEmail              String?       @map("parent_email") // captured at intake; enables OTP login + lms_account_ready notification
  studentName              String?       @map("student_name") // Student creation + multi-child disambiguation
  studentDob               DateTime?     @map("student_dob") @db.Date
  /// Optional: which class to enroll the student into at approve. Null = payment only, no class yet.
  classBatchId             String?       @map("class_batch_id") @db.Uuid
  classBatch               ClassBatch?   @relation("ReceiptBatch", fields: [classBatchId], references: [id], onDelete: SetNull)
  /// Reverse provenance: students and enrollments created atomically by this receipt.
  studentsCreated          Student[]     @relation("StudentProvenance")
  enrollmentsCreated       Enrollment[]  @relation("EnrollmentProvenance")

  @@unique([facilityId, code]) // codes are unique per facility; counters are keyed (facilityId, year)
  @@index([facilityId])
  @@index([studentId])
  @@index([soldById, status])
  @@index([classBatchId])
  @@map("receipt")
}

/// Bộ đếm sinh mã phiếu thu nguyên tử theo (cơ sở, năm).
model ReceiptCodeCounter {
  facilityId Int @map("facility_id")
  year       Int
  lastSeq    Int @default(0) @map("last_seq")

  @@id([facilityId, year])
  @@map("receipt_code_counter")
}

/// CRM pipeline (S2): O1 lead → O2 contacted → O3 test scheduled → O4 tested → O5 enrolled.
/// O3/O4 set bởi auto-hook (S3, từ TestAppointment); O2/O5 manual; cho lùi/re-open (audit).
enum OpportunityStage {
  O1_LEAD
  O2_CONTACTED
  O3_TEST_SCHEDULED
  O4_TESTED
  O5_ENROLLED
}

/// Lý do mất cơ hội — chuẩn hoá để phân tích phễu. `other` cho mọi trường hợp khác (kèm lostNote).
enum LostReason {
  price
  schedule
  distance
  competitor
  no_response
  not_ready
  other
}

/// Khách tiềm năng — facility-scoped. phone chuẩn hóa +84, dedup theo (cơ sở, phone).
model Contact {
  id            String        @id @default(uuid()) @db.Uuid
  facilityId    Int           @map("facility_id")
  fullName      String        @map("full_name")
  phone         String
  email         String?
  source        String? // web | walk_in | referral | ...
  medium        String? // cpc | organic | referral | event | ... (kênh con — quy nguồn marketing)
  campaign      String? // mã/tên chiến dịch marketing
  note          String?
  archivedAt    DateTime?     @map("archived_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  opportunities Opportunity[]

  @@unique([facilityId, phone])
  @@index([facilityId])
  @@map("contact")
}

/// Cơ hội bán hàng — facility-scoped. 1 opp = 1 HS/SĐT (nhiều con cùng SĐT → nhiều opp, phân biệt
/// studentName). lost = closedAt + lostReason; won = stage O5_ENROLLED + closedAt + nối enrollment.
model Opportunity {
  id          String                  @id @default(uuid()) @db.Uuid
  facilityId  Int                     @map("facility_id")
  contactId   String                  @map("contact_id") @db.Uuid
  // Restrict: xóa Contact KHÔNG được cuốn theo opportunity (giữ lịch sử hoa hồng/won-lost).
  contact     Contact                 @relation(fields: [contactId], references: [id], onDelete: Restrict)
  studentName String?                 @map("student_name")
  program     Program?
  stage       OpportunityStage        @default(O1_LEAD)
  /// Sales consultant (CVTV) credited with this opportunity — source of commission attribution
  /// (docs/specs/payroll-v2-commission-design.md). Flows onto the receipt's soldById at approve.
  ownerId     String?                 @map("owner_id") @db.Uuid
  lostReason  LostReason?             @map("lost_reason")
  lostNote    String?                 @map("lost_note") // ghi chú tự do kèm lý do mất (đặc biệt khi = other)
  closedAt    DateTime?               @map("closed_at")
  archivedAt  DateTime?               @map("archived_at")
  createdAt   DateTime                @default(now()) @map("created_at")
  tests       TestAppointment[]
  receipts    Receipt[]
  assignments OpportunityAssignment[]

  @@index([facilityId])
  @@index([contactId])
  @@index([ownerId])
  @@map("opportunity")
}

/// Sổ phân bổ cơ hội (append-only) — mọi lần set/đổi owner ghi 1 dòng để phục vụ KPI/hoa hồng & minh
/// bạch. KHÔNG sửa/xoá. fromOwnerId null = lần gán đầu (lúc tạo).
model OpportunityAssignment {
  id            String      @id @default(uuid()) @db.Uuid
  facilityId    Int         @map("facility_id")
  opportunityId String      @map("opportunity_id") @db.Uuid
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  fromOwnerId   String?     @map("from_owner_id") @db.Uuid
  toOwnerId     String?     @map("to_owner_id") @db.Uuid
  assignedById  String      @map("assigned_by_id") @db.Uuid
  reason        String?
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([facilityId])
  @@index([opportunityId])
  @@map("opportunity_assignment")
}

/// Doanh thu khách mới vs tái tục (PA2 hoa hồng tính khác nhau). Suy + đóng băng tại approve.
enum ReceiptKind {
  new
  renewal
}

/// Lịch test (S3) — facility-scoped. entrance: gắn opportunity → auto-hook O3 khi tạo, O4 khi chấm.
/// periodic: test định kỳ trong quá trình học (không đổi stage opp).
enum TestType {
  entrance
  periodic
}

enum TestStatus {
  scheduled
  done
  no_show
}

model TestAppointment {
  id            String       @id @default(uuid()) @db.Uuid
  facilityId    Int          @map("facility_id")
  opportunityId String?      @map("opportunity_id") @db.Uuid
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  studentName   String?      @map("student_name")
  type          TestType     @default(entrance)
  scheduledAt   DateTime     @map("scheduled_at")
  status        TestStatus   @default(scheduled)
  score         Float?
  result        String?
  gradedById    String?      @map("graded_by_id") @db.Uuid
  gradedAt      DateTime?    @map("graded_at")
  archivedAt    DateTime?    @map("archived_at")
  createdAt     DateTime     @default(now()) @map("created_at")

  @@index([facilityId])
  @@index([opportunityId])
  @@map("test_appointment")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 5 — After-sale (CSKH). Support cases linked to a student, with a status
// lifecycle + audit/chatter. Facility-scoped (RLS staff-by-facility).
// ─────────────────────────────────────────────────────────────────────────────
enum CaseStatus {
  open
  in_progress
  resolved
  closed
}

enum CasePriority {
  low
  normal
  high
}

model AfterSaleCase {
  id           String       @id @default(uuid()) @db.Uuid
  facilityId   Int          @map("facility_id")
  studentId    String?      @map("student_id") @db.Uuid
  student      Student?     @relation(fields: [studentId], references: [id], onDelete: SetNull)
  contactPhone String?      @map("contact_phone")
  subject      String
  description  String?
  category     String? // complaint | request | inquiry | refund | other (free-text)
  priority     CasePriority @default(normal)
  status       CaseStatus   @default(open)
  assignedToId String?      @map("assigned_to_id") @db.Uuid
  resolvedAt   DateTime?    @map("resolved_at")
  createdById  String?      @map("created_by_id") @db.Uuid
  archivedAt   DateTime?    @map("archived_at")
  createdAt    DateTime     @default(now()) @map("created_at")

  @@index([facilityId])
  @@index([studentId])
  @@map("after_sale_case")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase B — Staff in-app notification. SSE fan-out per facility. 4 event types.
// ─────────────────────────────────────────────────────────────────────────────

enum StaffNotifEvent {
  class_cancelled
  enrollment_new
  receipt_pending_approval
  kpi_pending_review
  chatter_note
  shift_reg_submitted
  shift_reg_approved
  shift_reg_rejected
  manual_punch_pending
}

model StaffNotification {
  id          String          @id @default(cuid())
  recipientId String          @map("recipient_id") @db.Uuid
  recipient   AppUser         @relation(fields: [recipientId], references: [id])
  event       StaffNotifEvent
  title       String
  body        String
  data        Json            @default("{}")
  readAt      DateTime?       @map("read_at")
  facilityId  Int             @map("facility_id")
  facility    Facility        @relation(fields: [facilityId], references: [id])
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([recipientId, readAt])
  @@index([facilityId])
  @@map("staff_notification")
}

/// Chứng chỉ — cấp TAY bởi head_teacher/quan_ly (LMS là nền làm bài tập, không tự cấp bằng;
/// duyệt level-up KHÔNG sinh chứng chỉ). Facility-scoped; render bản in HTML tại /files/certificate/:id.
model Certificate {
  id         String    @id @default(uuid()) @db.Uuid
  facilityId Int       @map("facility_id")
  studentId  String    @map("student_id") @db.Uuid
  student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  program    Program
  level      String?
  title      String
  issuedById String?   @map("issued_by_id") @db.Uuid
  issuedAt   DateTime  @default(now()) @map("issued_at")
  archivedAt DateTime? @map("archived_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([facilityId])
  @@index([studentId])
  @@map("certificate")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 4 — Nhân sự & Lương. Component-based payslip; PIT 7 bậc ở @cmc/domain-payroll.
// Facility-scoped RLS; "non-HR không thấy lương" enforced at the procedure layer
// (requireRole hr/ke_toan) — RLS hiện chưa có GUC theo role. Spec: phase-04-payroll.
// ─────────────────────────────────────────────────────────────────────────────
enum PayslipStatus {
  draft
  finalized
  paid
}

/// Hồ sơ nhân sự (mở rộng AppUser; userId là khóa, không khai báo quan hệ để giữ AppUser gọn).
model EmploymentProfile {
  id          String    @id @default(uuid()) @db.Uuid
  facilityId  Int       @map("facility_id")
  userId      String    @unique @map("user_id") @db.Uuid
  position    String // teacher | sales | lead_teacher | center_director | training_director …
  grade       String? // B1..B4, PT3…
  dependents  Int       @default(0)
  /// Callio (Phonenet) extension number — maps this user to their call records for KPI calls
  /// (decision 0010). Null = not on the dialer; call metrics resolve 0 for them.
  callioExt   String?   @map("callio_ext")
  /// Direct manager (reports-to). Null = auto-resolve by role: sale/cskh/ctv_mkt → giam_doc_kinh_doanh,
  /// giao_vien/head_teacher → giam_doc_dao_tao. Next-level = bgd or manager.managerId chain.
  /// Loose UUID reference (no FK — follows codebase pattern for AppUser refs like soldById).
  managerId   String?   @map("manager_id") @db.Uuid
  startedAt   DateTime? @map("started_at") @db.Date
  /// Địa chỉ thường trú (decision 0026 — sensitive, masked for non-privileged roles).
  address     String?   @map("address")
  /// Số CCCD/CMND (decision 0026 — sensitive, masked for non-privileged roles).
  nationalId  String?   @map("national_id")
  /// Số tài khoản ngân hàng (decision 0026 — sensitive, masked for non-privileged roles).
  bankAccount String?   @map("bank_account")
  /// Tên ngân hàng (decision 0026).
  bankName    String?   @map("bank_name")
  archivedAt  DateTime? @map("archived_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([facilityId])
  @@index([managerId])
  @@map("employment_profile")
}

/// Snapshot số liệu cuộc gọi Callio theo (nhân sự, kỳ) — đóng băng để payslip tái lập (decision
/// 0010). validCalls = cuộc gọi ra có billDuration > 5s. Facility-scoped RLS; HR/super đọc-ghi.
model CallMetric {
  id           String   @id @default(uuid()) @db.Uuid
  facilityId   Int      @map("facility_id")
  userId       String   @map("user_id") @db.Uuid
  periodKey    String   @map("period_key") // YYYY-MM
  validCalls   Int      @default(0) @map("valid_calls")
  totalCalls   Int      @default(0) @map("total_calls")
  totalTalkSec Int      @default(0) @map("total_talk_sec")
  syncedAt     DateTime @default(now()) @map("synced_at")

  @@unique([userId, periodKey])
  @@index([facilityId, periodKey])
  @@map("call_metric")
}

/// Trạng thái phiếu đánh giá KPI (P05, decision 0011): draft→submitted→confirmed→approved.
enum KpiStatus {
  draft
  submitted
  confirmed
  approved
}

/// Điểm KPI theo (nhân sự, kỳ) — auto tính từ dữ liệu + cho phép cấp trên override có lý do
/// (decision 0011). finalScore = overrideScore ?? autoScore. Mọi override ghi record_event để
/// minh bạch. Facility-scoped RLS. Payslip đọc finalScore khi tính (thay vì HR gõ tay).
/// P05: mở rộng thành phiếu đánh giá (Odoo-style) với workflow draft→submitted→confirmed→approved.
model KpiScore {
  id              String    @id @default(uuid()) @db.Uuid
  facilityId      Int       @map("facility_id")
  userId          String    @map("user_id") @db.Uuid
  periodKey       String    @map("period_key") // YYYY-MM
  block           String // 'training' | 'sales' — quyết định KPI band áp dụng
  autoScore       Float     @map("auto_score") // 0..100 tính từ dữ liệu
  autoBreakdown   Json?     @map("auto_breakdown") // [{ criterion, weight, score }]
  overrideScore   Float?    @map("override_score") // cấp trên chỉnh (0..100); null = dùng auto
  overrideReason  String?   @map("override_reason")
  overriddenById  String?   @map("overridden_by_id") @db.Uuid
  overriddenAt    DateTime? @map("overridden_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  // P05 workflow fields — phiếu đánh giá KPI kiểu Odoo
  status          KpiStatus @default(draft)
  criterionScores Json?     @map("criterion_scores") // [{key, score}] — điểm từng tiêu chí
  submittedById   String?   @map("submitted_by_id") @db.Uuid
  submittedAt     DateTime? @map("submitted_at")
  confirmedById   String?   @map("confirmed_by_id") @db.Uuid
  confirmedAt     DateTime? @map("confirmed_at")
  approvedById    String?   @map("approved_by_id") @db.Uuid
  approvedAt      DateTime? @map("approved_at")

  @@unique([userId, periodKey])
  @@index([facilityId, periodKey])
  @@map("kpi_score")
}

/// Mức lương hiệu lực theo thời điểm (per nhân sự). Áp dụng bản mới nhất effectiveFrom ≤ kỳ lương.
model SalaryRate {
  id             String    @id @default(uuid()) @db.Uuid
  facilityId     Int       @map("facility_id")
  userId         String    @map("user_id") @db.Uuid
  baseSalary     Int       @map("base_salary")
  mealAllowance  Int       @default(0) @map("meal_allowance")
  otherAllowance Int       @default(0) @map("other_allowance")
  kpiMax         Int       @default(0) @map("kpi_max")
  /// Chỉ tiêu doanh số tháng (VND) — mẫu số tính % đạt quota cho hoa hồng sale (PA2). 0 = không áp.
  monthlyQuota   Int       @default(0) @map("monthly_quota")
  effectiveFrom  DateTime  @map("effective_from") @db.Date
  archivedAt     DateTime? @map("archived_at")
  createdById    String?   @map("created_by_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")

  // Một mức lương hiệu lực duy nhất cho mỗi (nhân sự, ngày hiệu lực) → payslip xác định.
  @@unique([userId, effectiveFrom])
  @@index([facilityId])
  @@map("salary_rate")
}

/// Chính sách thu nhập effective-dated, company-wide (docs/specs/payroll-v2-commission-design.md).
/// `params` (JSON, validate bằng Zod ở @cmc/domain-payroll) chứa TOÀN BỘ tham số tunable: bảng %
/// hoa hồng theo bậc quota, % tái tục, KPI band theo khối, đơn giá vượt giờ, gói parttime, bậc PIT +
/// giảm trừ. Chỉ super_admin sửa (write); payslip đọc bản hiệu lực ≤ kỳ. Finalize đóng băng số đã
/// tính → sửa policy chỉ áp dụng kỳ sau (quá khứ an toàn). Không facility-scoped (chính sách toàn hệ).
model CompensationPolicy {
  id            String    @id @default(uuid()) @db.Uuid
  effectiveFrom DateTime  @map("effective_from") @db.Date
  params        Json
  note          String?
  createdById   String?   @map("created_by_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")
  archivedAt    DateTime? @map("archived_at")

  @@index([effectiveFrom])
  @@map("compensation_policy")
}

/// Phiếu lương theo (nhân sự, kỳ YYYY-MM). Số liệu khớp @cmc/domain-payroll. Finalize gating (M6):
/// chỉ tính lại khi draft; finalized đóng băng; paid = đã trả.
model Payslip {
  id                                String        @id @default(uuid()) @db.Uuid
  facilityId                        Int           @map("facility_id")
  userId                            String        @map("user_id") @db.Uuid
  periodKey                         String        @map("period_key") // YYYY-MM
  standardDays                      Int           @map("standard_days")
  workdays                          Int
  kpiScore                          Float         @map("kpi_score")
  kpiGrade                          String        @map("kpi_grade")
  baseEarned                        Int           @map("base_earned")
  allowanceEarned                   Int           @map("allowance_earned")
  kpiBonus                          Int           @map("kpi_bonus")
  variablePay                       Int           @default(0) @map("variable_pay")
  variableNote                      String?       @map("variable_note")
  insuranceDeduction                Int           @default(0) @map("insurance_deduction")
  attendanceDeduction               Int?          @map("attendance_deduction")
  attendanceDeductionOverride       Int?          @map("attendance_deduction_override")
  attendanceDeductionOverrideReason String?       @map("attendance_deduction_override_reason")
  attendanceDeductionOverrideById   String?       @map("attendance_deduction_override_by_id") @db.Uuid
  dependents                        Int           @default(0)
  grossIncome                       Int           @map("gross_income")
  taxableIncome                     Int           @map("taxable_income")
  pitAmount                         Int           @map("pit_amount")
  netIncome                         Int           @map("net_income")
  status                            PayslipStatus @default(draft)
  computedById                      String?       @map("computed_by_id") @db.Uuid
  finalizedById                     String?       @map("finalized_by_id") @db.Uuid
  finalizedAt                       DateTime?     @map("finalized_at")
  paidAt                            DateTime?     @map("paid_at")
  createdAt                         DateTime      @default(now()) @map("created_at")

  @@unique([userId, periodKey])
  @@index([facilityId, periodKey])
  @@map("payslip")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 6 — Work Shift Registration + Attendance. Staff-facing shift scheduling
// and punch-based check-in/check-out with IP validation.
// ─────────────────────────────────────────────────────────────────────────────

/// Trạng thái phiếu đăng ký ca: draft → submitted → approved. cancelled là terminal.
enum ShiftRegStatus {
  draft
  submitted
  approved
  cancelled
}

/// Loại ca trong phiếu: đi làm hoặc nghỉ phép (tích hợp chung 1 luồng).
enum ShiftEntryType {
  work
  leave
}

/// Nhóm ca làm việc (vd: KINH_DOANH, GIAO_VIEN). selectionMode = SINGLE | MULTIPLE.
/// Facility-scoped để mỗi cơ sở có thể cấu hình nhóm ca riêng.
model ShiftGroup {
  id            String    @id @default(uuid()) @db.Uuid
  facilityId    Int       @map("facility_id")
  code          String /// "KINH_DOANH", "GIAO_VIEN"
  name          String /// "Kinh doanh", "Giáo viên"
  selectionMode String    @map("selection_mode") /// "SINGLE" | "MULTIPLE"
  description   String?
  sortOrder     Int       @default(0) @map("sort_order")
  archivedAt    DateTime? @map("archived_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  templates     ShiftTemplate[]
  registrations ShiftRegistration[]

  @@unique([facilityId, code])
  @@index([facilityId])
  @@map("shift_group")
}

/// Mẫu ca trong nhóm (vd: Ca sáng 08:00-12:00). startTime/endTime dạng "HH:mm".
model ShiftTemplate {
  id           String     @id @default(uuid()) @db.Uuid
  facilityId   Int        @map("facility_id")
  shiftGroupId String     @map("shift_group_id") @db.Uuid
  shiftGroup   ShiftGroup @relation(fields: [shiftGroupId], references: [id], onDelete: Cascade)
  code         String /// "CA_SANG", "CA_CHIEU", "CA_TOI"
  name         String /// "Ca sáng", "Ca chiều", "Ca tối"
  startTime    String     @map("start_time") /// "08:00"
  endTime      String     @map("end_time") /// "12:00"
  hours        Float      @default(0) /// Tổng giờ ca (8.0 cho KD, 4.0 cho GV)
  color        String? /// Mã màu hiển thị (hex)
  sortOrder    Int        @default(0) @map("sort_order")
  archivedAt   DateTime?  @map("archived_at")
  createdAt    DateTime   @default(now()) @map("created_at")

  registrationEntries ShiftRegistrationEntry[]
  timePunches         TimePunch[]

  @@unique([shiftGroupId, code]) /// Mã ca duy nhất trong nhóm
  @@unique([shiftGroupId, startTime]) /// Không trùng giờ trong cùng nhóm
  @@index([facilityId])
  @@index([shiftGroupId])
  @@map("shift_template")
}

/// Phiếu đăng ký ca (1 phiếu = 1 nhân viên, 1 khoảng thời gian).
/// Workflow: draft → submitted → approved. Khi phiếu mới APPROVED, phiếu cũ bị cancelled
/// (supersededById trỏ đến phiếu mới).
model ShiftRegistration {
  id             String         @id @default(uuid()) @db.Uuid
  facilityId     Int            @map("facility_id")
  code           String?        @map("code") /// SR-YYYY-NNNN (sinh khi submit)
  userId         String         @map("user_id") @db.Uuid
  fromDate       DateTime       @map("from_date") @db.Date
  toDate         DateTime       @map("to_date") @db.Date
  status         ShiftRegStatus @default(draft)
  shiftGroupId   String         @map("shift_group_id") @db.Uuid
  shiftGroup     ShiftGroup     @relation(fields: [shiftGroupId], references: [id])
  /// Manager info — frozen at submit
  managerId      String?        @map("manager_id") @db.Uuid
  nextManagerId  String?        @map("next_manager_id") @db.Uuid
  /// Audit trail
  submittedAt    DateTime?      @map("submitted_at")
  submittedById  String?        @map("submitted_by_id") @db.Uuid
  approvedAt     DateTime?      @map("approved_at")
  approvedById   String?        @map("approved_by_id") @db.Uuid
  rejectReason   String?        @map("reject_reason")
  /// Supersede chain
  supersededById String?        @map("superseded_by_id") @db.Uuid /// Phiếu thay thế
  supersededAt   DateTime?      @map("superseded_at")
  archivedAt     DateTime?      @map("archived_at")
  createdAt      DateTime       @default(now()) @map("created_at")

  entries ShiftRegistrationEntry[]

  @@unique([facilityId, code])
  @@index([facilityId, userId])
  @@index([facilityId, status])
  @@index([userId, fromDate, toDate])
  @@map("shift_registration")
}

/// Một dòng đăng ký = 1 ngày + 1 ca + type (work|leave). Flat structure.
model ShiftRegistrationEntry {
  id              String            @id @default(uuid()) @db.Uuid
  registrationId  String            @map("registration_id") @db.Uuid
  registration    ShiftRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  date            DateTime          @db.Date
  shiftTemplateId String            @map("shift_template_id") @db.Uuid
  shiftTemplate   ShiftTemplate     @relation(fields: [shiftTemplateId], references: [id])
  type            ShiftEntryType    @default(work)
  hours           Float             @default(0) /// Giờ ca này (copy từ ShiftTemplate để audit)
  createdAt       DateTime          @default(now()) @map("created_at")

  @@unique([registrationId, date, shiftTemplateId]) /// Mỗi ca chỉ chọn 1 lần/ngày/phiếu
  @@index([registrationId])
  @@index([date])
  @@map("shift_registration_entry")
}

/// Bản ghi chấm công — mỗi lần bấm nút = 1 punch. Cuối ngày: punch sớm nhất = check-in,
/// muộn nhất = check-out. ShiftTemplate FK optional (null nếu punch không map vào ca đã đăng ký).
model TimePunch {
  id              String         @id @default(uuid()) @db.Uuid
  facilityId      Int            @map("facility_id")
  userId          String         @map("user_id") @db.Uuid
  timestamp       DateTime       @default(now())
  ipAddress       String         @map("ip_address")
  userAgent       String?        @map("user_agent")
  method          String         @default("ip") /// "ip" | "manual" — cách chấm công
  shiftTemplateId String?        @map("shift_template_id") @db.Uuid
  shiftTemplate   ShiftTemplate? @relation(fields: [shiftTemplateId], references: [id])
  /// Manual attendance approval
  approvedById    String?        @map("approved_by_id") @db.Uuid
  approvedAt      DateTime?      @map("approved_at")
  createdAt       DateTime       @default(now()) @map("created_at")

  @@index([facilityId, userId, timestamp])
  @@index([userId, timestamp])
  @@index([shiftTemplateId])
  @@map("time_punch")
}

/// Cấu hình IP cho check-in theo cơ sở. Hỗ trợ CIDR range (vd: 192.168.1.0/24).
model FacilityNetwork {
  id         String    @id @default(uuid()) @db.Uuid
  facilityId Int       @map("facility_id")
  ipAddress  String    @map("ip_address") /// "192.168.1.0/24" hoặc "152.42.167.189"
  label      String? /// "WiFi VP chính"
  isActive   Boolean   @default(true) @map("is_active")
  archivedAt DateTime? @map("archived_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@unique([facilityId, ipAddress])
  @@index([facilityId])
  @@map("facility_network")
}

/// Bộ đếm sinh mã phiếu đăng ký ca nguyên tử theo (cơ sở, năm).
model ShiftCodeCounter {
  facilityId Int @map("facility_id")
  year       Int
  lastSeq    Int @default(0) @map("last_seq")

  @@id([facilityId, year])
  @@map("shift_code_counter")
}

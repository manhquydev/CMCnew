// CMCnew — canonical schema (single source of truth).
// Phase 0: identity + multi-facility tenancy foundation. Later phases extend this.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Business roles. Facility scope is enforced via RLS, not via role.
enum Role {
  super_admin
  quan_ly
  head_teacher
  giao_vien
  ke_toan
  hr
  sale
  cskh
  ctv_mkt
  bgd
}

/// The 3 CMC programs. Global (not facility-scoped).
enum Program {
  UCREA
  BRIGHT_IG
  BLACK_HOLE
}

enum StudentLifecycle {
  admitted
  active
  on_hold
  transferred
  withdrawn
  completed
}

enum ClassStatus {
  planned
  open
  running
  closed
  cancelled
}

enum SessionStatus {
  planned
  confirmed
  cancelled
}

enum EnrollmentStatus {
  active
  completed
  reserved
  transferred
  withdrawn
}

enum AttendanceStatus {
  present
  absent
  late
}

/// Audit/chatter timeline entry kinds (Odoo-style record log).
enum RecordEventType {
  created
  updated
  status_changed
  archived
  restored
  note
}

/// A training center (cơ sở). Tenancy boundary — RLS isolates rows by facility.
model Facility {
  id        Int            @id @default(autoincrement())
  code      String         @unique
  name      String
  timezone  String         @default("Asia/Ho_Chi_Minh")
  address   String?
  isActive  Boolean        @default(true) @map("is_active")
  createdAt DateTime       @default(now()) @map("created_at")
  users     UserFacility[]

  @@map("facility")
}

/// A staff/admin account. Students & parents get their own models in later phases.
model AppUser {
  id           String         @id @default(uuid()) @db.Uuid
  email        String         @unique
  phone        String?
  displayName  String         @map("display_name")
  passwordHash String         @map("password_hash")
  roles        Role[]
  primaryRole  Role           @map("primary_role")
  isActive     Boolean        @default(true) @map("is_active")
  /// Bumped on deactivate / role / facility change → invalidates outstanding JWTs.
  tokenVersion Int            @default(0) @map("token_version")
  createdAt    DateTime       @default(now()) @map("created_at")
  facilities   UserFacility[]

  @@map("app_user")
}

/// Many-to-many: which facilities a user may access.
model UserFacility {
  userId     String   @map("user_id") @db.Uuid
  facilityId Int      @map("facility_id")
  user       AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@id([userId, facilityId])
  @@map("user_facility")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 1 — Academic core. Program + Course are GLOBAL (shared catalog, no RLS).
// Everything from ClassBatch down carries facility_id and is RLS-scoped.
// Soft-delete everywhere via `archivedAt` (null = active). Never hard-delete.
// ─────────────────────────────────────────────────────────────────────────────

/// Course catalog — GLOBAL (dùng chung mọi cơ sở). No facility_id, no RLS.
model Course {
  id          String       @id @default(uuid()) @db.Uuid
  code        String       @unique
  name        String
  program     Program
  description String?
  archivedAt  DateTime?    @map("archived_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  batches     ClassBatch[]

  @@map("course")
}

/// Học sinh — facility-scoped.
model Student {
  id          String           @id @default(uuid()) @db.Uuid
  facilityId  Int              @map("facility_id")
  studentCode String           @unique @map("student_code")
  fullName    String           @map("full_name")
  dateOfBirth DateTime?        @map("date_of_birth") @db.Date
  program     Program
  level       String? // mô hình level chốt ở Phase 2
  lifecycle   StudentLifecycle @default(admitted)
  archivedAt  DateTime?        @map("archived_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  enrollments Enrollment[]
  account         StudentAccount?
  guardians       Guardian[]
  submissions     Submission[]
  starTransactions StarTransaction[]
  rewards         Reward[]
  qualitativeAssessments QualitativeAssessment[]
  finalGrades     FinalGrade[]
  badges          StudentBadge[]

  @@index([facilityId])
  @@map("student")
}

/// Lớp/khóa cụ thể — facility-scoped. Mã B-YYYY-NNNN (sinh nguyên tử).
model ClassBatch {
  id         String         @id @default(uuid()) @db.Uuid
  facilityId Int            @map("facility_id")
  code       String         @unique
  courseId   String         @map("course_id") @db.Uuid
  course     Course         @relation(fields: [courseId], references: [id])
  name       String
  startDate  DateTime?      @map("start_date") @db.Date
  endDate    DateTime?      @map("end_date") @db.Date
  capacity   Int?
  status     ClassStatus    @default(planned)
  archivedAt DateTime?      @map("archived_at")
  createdAt  DateTime       @default(now()) @map("created_at")
  slots      ScheduleSlot[]
  sessions   ClassSession[]
  enrollments Enrollment[]
  exercises  Exercise[]

  @@index([facilityId])
  @@map("class_batch")
}

/// Phòng học — facility-scoped.
model Room {
  id         String    @id @default(uuid()) @db.Uuid
  facilityId Int       @map("facility_id")
  code       String
  name       String
  capacity   Int?
  archivedAt DateTime? @map("archived_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@unique([facilityId, code])
  @@index([facilityId])
  @@map("room")
}

/// Khung lịch tuần của lớp → dùng để sinh Session.
model ScheduleSlot {
  id           String     @id @default(uuid()) @db.Uuid
  facilityId   Int        @map("facility_id")
  classBatchId String     @map("class_batch_id") @db.Uuid
  batch        ClassBatch @relation(fields: [classBatchId], references: [id], onDelete: Cascade)
  dayOfWeek    Int        @map("day_of_week") // 0=CN .. 6=T7
  startTime    String     @map("start_time") // HH:mm (ICT)
  endTime      String     @map("end_time")
  roomId       String?    @map("room_id") @db.Uuid
  teacherId    String?    @map("teacher_id") @db.Uuid
  archivedAt   DateTime?  @map("archived_at")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([facilityId])
  @@index([classBatchId])
  @@map("schedule_slot")
}

/// Buổi học cụ thể — sinh từ slot, hoặc buổi bù.
model ClassSession {
  id           String        @id @default(uuid()) @db.Uuid
  facilityId   Int           @map("facility_id")
  classBatchId String        @map("class_batch_id") @db.Uuid
  batch        ClassBatch    @relation(fields: [classBatchId], references: [id], onDelete: Cascade)
  sessionDate  DateTime      @map("session_date") @db.Date
  startTime    String        @map("start_time")
  endTime      String        @map("end_time")
  roomId       String?       @map("room_id") @db.Uuid
  teacherId    String?       @map("teacher_id") @db.Uuid
  status       SessionStatus @default(planned)
  isMakeup     Boolean       @default(false) @map("is_makeup")
  archivedAt   DateTime?     @map("archived_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  attendances  Attendance[]

  @@unique([classBatchId, sessionDate, startTime])
  @@index([facilityId])
  @@map("class_session")
}

/// Ghi danh học sinh vào lớp.
model Enrollment {
  id            String           @id @default(uuid()) @db.Uuid
  facilityId    Int              @map("facility_id")
  classBatchId  String           @map("class_batch_id") @db.Uuid
  batch         ClassBatch       @relation(fields: [classBatchId], references: [id], onDelete: Cascade)
  studentId     String           @map("student_id") @db.Uuid
  student       Student          @relation(fields: [studentId], references: [id])
  status        EnrollmentStatus @default(active)
  opportunityId String?          @map("opportunity_id") // truy vết CRM (Phase 3)
  archivedAt    DateTime?        @map("archived_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  attendances   Attendance[]

  @@unique([classBatchId, studentId])
  @@index([facilityId])
  @@map("enrollment")
}

/// Điểm danh — 1 bản ghi / (session, enrollment).
model Attendance {
  id             String           @id @default(uuid()) @db.Uuid
  facilityId     Int              @map("facility_id")
  classSessionId String           @map("class_session_id") @db.Uuid
  session        ClassSession     @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  enrollmentId   String           @map("enrollment_id") @db.Uuid
  enrollment     Enrollment       @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  status         AttendanceStatus
  excused        Boolean          @default(false)
  note           String?
  markedById     String?          @map("marked_by_id") @db.Uuid
  markedAt       DateTime?        @map("marked_at")
  createdAt      DateTime         @default(now()) @map("created_at")

  @@unique([classSessionId, enrollmentId])
  @@index([facilityId])
  @@map("attendance")
}

/// Bộ đếm sinh mã lớp nguyên tử theo (cơ sở, năm).
model BatchCodeCounter {
  facilityId Int @map("facility_id")
  year       Int
  lastSeq    Int @default(0) @map("last_seq")

  @@id([facilityId, year])
  @@map("batch_code_counter")
}

// ── Audit / Chatter (Odoo-style) — cross-cutting timeline on every record ──

/// Một dòng timeline cho một record bất kỳ (thay đổi field/trạng thái hoặc ghi chú).
model RecordEvent {
  id         String          @id @default(uuid()) @db.Uuid
  facilityId Int?            @map("facility_id") // null cho record global (vd Course)
  entityType String          @map("entity_type")
  entityId   String          @map("entity_id")
  type       RecordEventType
  changes    Json? // [{ field, old, new }]
  body       String? // nội dung ghi chú / lý do (vd lý do hủy lớp)
  actorId    String?         @map("actor_id") @db.Uuid
  createdAt  DateTime        @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([facilityId])
  @@map("record_event")
}

/// Người theo dõi một record (nhận thông báo — Phase sau).
model RecordFollower {
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  userId     String   @map("user_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  @@id([entityType, entityId, userId])
  @@map("record_follower")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 2 — Đánh giá & LMS học sinh. HS/PH có model định danh RIÊNG (tách AppUser).
// Slice S1: Exercise → Submission → Grade → Star → Reward. Spec: phase-02-assessment-lms.
// Bài nộp = đề PDF gốc (1 lần) + lớp annotation JSON (không lưu PDF phẳng).
// ─────────────────────────────────────────────────────────────────────────────

enum ExerciseType {
  homework
  test_entrance
  test_periodic
}

enum ExerciseStatus {
  draft
  published
  closed
}

enum SubmissionStatus {
  draft
  submitted
  graded
}

/// Loại giao dịch sao: + earn / - spent. reference để chống cộng/trừ trùng.
enum StarTxnType {
  homework_completed
  gift_redeemed
  gift_rejected_refund
  manual
}

enum BadgeSource {
  auto
  manual
}

enum RewardStatus {
  pending
  approved
  rejected
}

enum GuardianRelation {
  father
  mother
  guardian
}

/// Tài khoản đăng nhập của phụ huynh (login chính phía LMS). Định danh riêng, không phải AppUser.
model ParentAccount {
  id           String     @id @default(uuid()) @db.Uuid
  email        String?    @unique
  phone        String?    @unique
  displayName  String     @map("display_name")
  passwordHash String     @map("password_hash")
  isActive     Boolean    @default(true) @map("is_active")
  /// Bump khi khóa tài khoản / đổi quyền → vô hiệu JWT đang phát hành.
  tokenVersion Int        @default(0) @map("token_version")
  createdAt    DateTime   @default(now()) @map("created_at")
  guardians    Guardian[]

  @@map("parent_account")
}

/// Tài khoản đăng nhập tùy chọn của học sinh (PIN/mã đơn giản; HS 3–11 tuổi).
model StudentAccount {
  id           String   @id @default(uuid()) @db.Uuid
  studentId    String   @unique @map("student_id") @db.Uuid
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  loginCode    String   @unique @map("login_code")
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  tokenVersion Int      @default(0) @map("token_version")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("student_account")
}

/// Liên kết phụ huynh ↔ học sinh (sửa lỗ A3 hệ cũ). Facility-scoped qua student.
model Guardian {
  id              String           @id @default(uuid()) @db.Uuid
  facilityId      Int              @map("facility_id")
  parentAccountId String           @map("parent_account_id") @db.Uuid
  parent          ParentAccount    @relation(fields: [parentAccountId], references: [id], onDelete: Cascade)
  studentId       String           @map("student_id") @db.Uuid
  student         Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  relation        GuardianRelation @default(guardian)
  createdAt       DateTime         @default(now()) @map("created_at")

  @@unique([parentAccountId, studentId])
  @@index([facilityId])
  @@index([studentId])
  @@map("guardian")
}

/// Bài tập GV giao theo lớp. Đề gốc PDF lưu 1 lần (content-addressed) ở MinIO.
model Exercise {
  id           String         @id @default(uuid()) @db.Uuid
  facilityId   Int            @map("facility_id")
  classBatchId String         @map("class_batch_id") @db.Uuid
  batch        ClassBatch     @relation(fields: [classBatchId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  basePdfRef   String?        @map("base_pdf_ref")
  maxScore     Float          @default(10) @map("max_score")
  starReward   Int            @default(10) @map("star_reward")
  dueAt        DateTime?      @map("due_at")
  type         ExerciseType   @default(homework)
  status       ExerciseStatus @default(draft)
  createdById  String?        @map("created_by_id") @db.Uuid
  archivedAt   DateTime?      @map("archived_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  submissions  Submission[]

  @@index([facilityId])
  @@index([classBatchId])
  @@map("exercise")
}

/// Bài nộp của HS = answerText? + lớp annotation JSON (HS làm bài trên đề gốc). Không lưu PDF phẳng.
model Submission {
  id              String           @id @default(uuid()) @db.Uuid
  facilityId      Int              @map("facility_id")
  exerciseId      String           @map("exercise_id") @db.Uuid
  exercise        Exercise         @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  studentId       String           @map("student_id") @db.Uuid
  student         Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answerText      String?          @map("answer_text")
  annotationLayer Json?            @map("annotation_layer")
  version         Int              @default(1)
  status          SubmissionStatus @default(draft)
  submittedAt     DateTime?        @map("submitted_at")
  archivedAt      DateTime?        @map("archived_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  grade           Grade?

  @@unique([exerciseId, studentId])
  @@index([facilityId])
  @@map("submission")
}

/// Điểm 1 bài nộp. GV chấm trên bài qua lớp annotation riêng. Publish → HS/PH thấy + cộng sao.
model Grade {
  id              String     @id @default(uuid()) @db.Uuid
  facilityId      Int        @map("facility_id")
  submissionId    String     @unique @map("submission_id") @db.Uuid
  submission      Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  score           Float
  maxScore        Float      @default(10) @map("max_score")
  feedback        String?
  rubric          Json?
  annotationLayer Json?      @map("annotation_layer")
  gradedById      String?    @map("graded_by_id") @db.Uuid
  gradedAt        DateTime   @default(now()) @map("graded_at")
  isPublished     Boolean    @default(false) @map("is_published")
  createdAt       DateTime   @default(now()) @map("created_at")

  @@index([facilityId])
  @@map("grade")
}

/// Quà đổi sao — facility-scoped (mỗi cơ sở tự quản kho). stock -1 = vô hạn.
model Gift {
  id            String    @id @default(uuid()) @db.Uuid
  facilityId    Int       @map("facility_id")
  name          String
  description   String?
  imageUrl      String?   @map("image_url")
  starsRequired Int       @map("stars_required")
  stock         Int       @default(-1)
  program       Program?
  minLevel      String?   @map("min_level")
  isActive      Boolean   @default(true) @map("is_active")
  archivedAt    DateTime? @map("archived_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  rewards       Reward[]

  @@index([facilityId])
  @@map("gift")
}

/// Sổ cái sao (số dư = SUM(amount)). @@unique(type, reference) → earn/redeem idempotent.
model StarTransaction {
  id         String      @id @default(uuid()) @db.Uuid
  facilityId Int         @map("facility_id")
  studentId  String      @map("student_id") @db.Uuid
  student    Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount     Int
  type       StarTxnType
  reference  String?
  createdAt  DateTime    @default(now()) @map("created_at")

  @@unique([type, reference])
  @@index([studentId, createdAt])
  @@index([facilityId])
  @@map("star_transaction")
}

/// Đổi quà: trừ sao + kho nguyên tử; pending → duyệt; rejected → hoàn sao.
model Reward {
  id           String       @id @default(uuid()) @db.Uuid
  facilityId   Int          @map("facility_id")
  studentId    String       @map("student_id") @db.Uuid
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  giftId       String       @map("gift_id") @db.Uuid
  gift         Gift         @relation(fields: [giftId], references: [id])
  starsSpent   Int          @map("stars_spent")
  status       RewardStatus @default(pending)
  reviewedById String?      @map("reviewed_by_id") @db.Uuid
  reviewedAt   DateTime?    @map("reviewed_at")
  reason       String?
  createdAt    DateTime     @default(now()) @map("created_at")

  @@index([studentId])
  @@index([facilityId])
  @@map("reward")
}

/// Thông báo (polymorphic recipient). Fan-out realtime qua SSE. type mở rộng dần tới 16 loại.
model Notification {
  id            String    @id @default(uuid()) @db.Uuid
  facilityId    Int?      @map("facility_id")
  recipientType String    @map("recipient_type")
  recipientId   String    @map("recipient_id") @db.Uuid
  type          String
  payload       Json?
  readAt        DateTime? @map("read_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([recipientType, recipientId, readAt])
  @@index([facilityId])
  @@map("notification")
}

/// Huy hiệu (S3) — danh mục facility-scoped. unlockCriteria (Json) do @cmc/domain-rewards diễn giải.
model Badge {
  id             String         @id @default(uuid()) @db.Uuid
  facilityId     Int            @map("facility_id")
  code           String         @map("code")
  name           String
  description    String?
  iconUrl        String?        @map("icon_url")
  unlockCriteria Json           @map("unlock_criteria")
  isActive       Boolean        @default(true) @map("is_active")
  archivedAt     DateTime?      @map("archived_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  awards         StudentBadge[]

  @@unique([facilityId, code])
  @@index([facilityId])
  @@map("badge")
}

/// Huy hiệu HS đã đạt (S3). 1 lần/(student, badge). source = auto (đạt tiêu chí) | manual (GV cấp).
model StudentBadge {
  id          String      @id @default(uuid()) @db.Uuid
  facilityId  Int         @map("facility_id")
  studentId   String      @map("student_id") @db.Uuid
  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  badgeId     String      @map("badge_id") @db.Uuid
  badge       Badge       @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  source      BadgeSource @default(auto)
  awardedById String?     @map("awarded_by_id") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at")

  @@unique([studentId, badgeId])
  @@index([studentId])
  @@index([facilityId])
  @@map("student_badge")
}

/// Học bạ & tổng hợp (Phase 2 / S2). Logic số nằm ở @cmc/domain-grading.

enum AssessmentPeriod {
  MONTHLY
  END_LEVEL
}

/// Cấu hình chấm theo chương trình — facility-scoped catalog. formula = trọng số định lượng
/// { homework, test, attendance }; criteria = danh sách pillar định tính.
model GradingTemplate {
  id         String             @id @default(uuid()) @db.Uuid
  facilityId Int                @map("facility_id")
  program    Program
  level      String?
  formula    Json
  criteria   Json?
  thresholds GradingThreshold[]
  archivedAt DateTime?          @map("archived_at")
  createdAt  DateTime           @default(now()) @map("created_at")

  @@unique([facilityId, program, level])
  @@index([facilityId])
  @@map("grading_template")
}

/// Ngưỡng % → điểm chữ + kết quả (đạt/chưa), theo template. sequence để sắp xếp.
model GradingThreshold {
  id         String          @id @default(uuid()) @db.Uuid
  facilityId Int             @map("facility_id")
  templateId String          @map("template_id") @db.Uuid
  template   GradingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  minPercent Float           @map("min_percent")
  maxPercent Float           @map("max_percent")
  grade      String
  result     String
  sequence   Int             @default(0)

  @@index([templateId])
  @@index([facilityId])
  @@map("grading_threshold")
}

/// Đánh giá định tính theo (student, period). criteria = { pillar: 0..10 }. 1/(student, periodKey).
model QualitativeAssessment {
  id           String           @id @default(uuid()) @db.Uuid
  facilityId   Int              @map("facility_id")
  studentId    String           @map("student_id") @db.Uuid
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  program      Program?
  level        String?
  period       AssessmentPeriod
  periodKey    String           @map("period_key")
  criteria     Json
  narrative    String?
  assessedById String?          @map("assessed_by_id") @db.Uuid
  archivedAt   DateTime?        @map("archived_at")
  createdAt    DateTime         @default(now()) @map("created_at")

  @@unique([studentId, periodKey])
  @@index([facilityId])
  @@map("qualitative_assessment")
}

/// FinalGrade tổng hợp theo (student, program, period). Idempotent theo khóa; complete=false khi
/// còn thiếu phần có trọng số (điểm provisional).
model FinalGrade {
  id               String   @id @default(uuid()) @db.Uuid
  facilityId       Int      @map("facility_id")
  studentId        String   @map("student_id") @db.Uuid
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  program          Program
  level            String?
  periodKey        String   @map("period_key")
  homeworkAvg      Float?   @map("homework_avg")
  attendanceRate   Float?   @map("attendance_rate")
  testScore        Float?   @map("test_score")
  qualitativeScore Float?   @map("qualitative_score")
  finalScore       Float?   @map("final_score")
  passed           Boolean  @default(false)
  complete         Boolean  @default(false)
  computedAt       DateTime @default(now()) @map("computed_at")

  @@unique([studentId, program, periodKey])
  @@index([facilityId])
  @@map("final_grade")
}
